# Predator Analytics v25.0 - Production Environment Variables
# MANDATORY: Static IP / Domain deployment - NO localhost for external access

# ========================================
# SERVER CONFIGURATION
# ========================================
# PRODUCTION SERVER Static IP
SERVER_IP=194.177.1.240
DOMAIN=predator.analytics.local

# ========================================
# FRONTEND CONFIGURATION
# ========================================
# Public URLs (NO localhost)
FRONTEND_URL=https://predator.analytics.local
FRONTEND_DEV_URL=https://predator.analytics.local
API_BASE_URL=https://predator.analytics.local/api/v1

# Vite proxy targets (internal container networking)
VITE_API_URL=https://predator.analytics.local/api/v1
VITE_BACKEND_PROXY_TARGET=http://172.20.0.4:8000

# ========================================
# BACKEND CONFIGURATION
# ========================================
# Service binding (MANDATORY: 0.0.0.0)
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated, NO localhost)
CORS_ORIGINS=https://predator.analytics.local,https://www.predator.analytics.local

# ========================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL (internal container networking)
DATABASE_URL=postgresql+asyncpg://predator:YOUR_POSTGRES_PASSWORD@postgres:5432/predator_db
POSTGRES_URL=postgresql://predator:YOUR_POSTGRES_PASSWORD@postgres:5432/predator_db
POSTGRES_PASSWORD=YOUR_SECURE_POSTGRES_PASSWORD

# Redis (internal container networking)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ========================================
# SEARCH & VECTOR DATABASES
# ========================================
# OpenSearch (internal container networking)
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_PASSWORD=YOUR_SECURE_OPENSEARCH_PASSWORD

# Qdrant (internal container networking)
QDRANT_URL=http://qdrant:6333

# ========================================
# MLOPS CONFIGURATION
# ========================================
# MLflow (internal container networking)
MLFLOW_URL=http://mlflow:5000

# ========================================
# MONITORING CONFIGURATION
# ========================================
# Grafana
GRAFANA_PASSWORD=YOUR_SECURE_GRAFANA_PASSWORD
GRAFANA_DOMAIN=predator.analytics.local

# ========================================
# SECURITY CONFIGURATION
# ========================================
# JWT
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ========================================
# EXTERNAL APIS
# ========================================
# LLM Providers (API keys required)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Ukrainian Data Sources
PROZORRO_API_URL=https://public.api.openprocurement.org/api/2.5
EDR_API_URL=https://data.gov.ua/api/3/action
NBU_API_URL=https://bank.gov.ua/NBUStatService/v1
CUSTOMS_API_URL=https://cabinet.customs.gov.ua/api
COURT_API_URL=https://reyestr.court.gov.ua/api

# ========================================
# INFRASTRUCTURE CONFIGURATION
# ========================================
# MinIO (internal container networking)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=predator_admin
MINIO_SECRET_KEY=YOUR_SECURE_MINIO_SECRET_KEY

# Vault (if used)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=YOUR_VAULT_TOKEN

# ========================================
# LOGGING CONFIGURATION
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========================================
# PERFORMANCE CONFIGURATION
# ========================================
# Database
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# API
API_RATE_LIMIT=100
API_RATE_WINDOW=60

# Task Queue
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# ==================== TELEGRAM BOT V2.0 CONFIGURATION ====================

# === TELEGRAM БАЗОВІ НАЛАШТУВАННЯ (ОБОВ'ЯЗКОВО) ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ADMIN_ID=123456789  # Ваш Telegram User ID

# === TELEGRAM CHANNEL (ОПЦІОНАЛЬНО) ===
# Для дублювання важливих нотифікацій в канал
TELEGRAM_CHANNEL_ID=@your_channel_name
# Або використовуйте chat_id: -100123456789

# === REDIS (ДЛЯ POWER MONITOR ТА ЧЕРГИ ЗАДАЧ) ===
REDIS_URL=redis://redis:6379/1

# === GOOGLE CLOUD VOICE (ОПЦІОНАЛЬНО) ===
# Для підтримки голосових повідомлень (STT/TTS)
# Отримайте credentials: https://console.cloud.google.com/apis/credentials
GOOGLE_APPLICATION_CREDENTIALS=/app/config/google-cloud-credentials.json

# === DATABASE (ДЛЯ ЗБЕРІГАННЯ ІСТОРІЇ) ===
POSTGRES_URL=postgresql://predator:password@postgres:5432/predator

# === AI MODELS API KEYS ===
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key

# === OLLAMA (LOCAL LLM - ОПЦІОНАЛЬНО) ===
OLLAMA_BASE_URL=http://localhost:11434

# === POWER MONITOR НАЛАШТУВАННЯ ===
# Інтервал heartbeat в секундах (за замовчуванням 30)
POWER_MONITOR_HEARTBEAT_INTERVAL=30
# Інтервал uptime reports в хвилинах (за замовчуванням 30, 0 = вимкнено)
POWER_MONITOR_REPORT_INTERVAL=30

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=/app/orchestrator/system.log

# ==================== ДОДАТКОВІ ОПЦІЇ ====================

# === DOCKER ===
# Шлях до Docker socket (зазвичай не треба міняти)
DOCKER_HOST=unix:///var/run/docker.sock

# === NOTIFICATIONS ===
# Вимкнути звук для low-priority нотифікацій
DISABLE_NOTIFICATION_LOW_PRIORITY=true

# === VOICE SETTINGS ===
# Мова за замовчуванням для STT
VOICE_DEFAULT_LANGUAGE=uk-UA
# Альтернативна мова для fallback
VOICE_FALLBACK_LANGUAGE=ru-RU
# Стать голосу для TTS (MALE, FEMALE, NEUTRAL)
VOICE_TTS_GENDER=NEUTRAL

# === SECURITY ===
# Список дозволених Telegram User IDs (через кому)
TELEGRAM_ALLOWED_USERS=123456789,987654321
# Режим: strict (тільки allowed users), permissive (всі можуть читати, тільки allowed можуть керувати)
TELEGRAM_SECURITY_MODE=strict

# === RATE LIMITING ===
# Максимальна кількість команд на хвилину від одного користувача
RATE_LIMIT_PER_MINUTE=30

# === EXPERIMENTAL FEATURES ===
# Увімкнути автоматичне створення задач з голосових команд
VOICE_AUTO_TASK_CREATION=true
# Увімкнути NLU (Natural Language Understanding) через LLM
VOICE_NLU_ENABLED=true
# Модель для NLU
VOICE_NLU_MODEL=gemini

# ==================== ПРИКЛАД ПРАВИЛЬНО ЗАПОВНЕНОГО ====================
# TELEGRAM_BOT_TOKEN=6123456789:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw
# TELEGRAM_ADMIN_ID=123456789
# TELEGRAM_CHANNEL_ID=@predator_alerts
# REDIS_URL=redis://localhost:6379/1
# GOOGLE_APPLICATION_CREDENTIALS=/Users/you/predator/config/google-key.json
# GEMINI_API_KEY=AIzaSyC...

{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "Ultra-Router v5.0 — LiteLLM метрики",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "expr": "sum(rate(litellm_requests_metric_total[5m])) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Запити/хв за моделлю",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 2},
            {"color": "red", "value": 5}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(litellm_request_total_latency_metric_bucket[5m])) by (le, model))",
          "legendFormat": "p95 {{model}}",
          "refId": "A"
        }
      ],
      "title": "Latency p95 за моделлю (сек)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "expr": "sum(increase(litellm_requests_metric_total{status_code=~\"4..|5..\"}[5m])) by (model)",
          "legendFormat": "Помилки {{model}}",
          "refId": "A"
        }
      ],
      "title": "Помилки за моделлю (5хв вікно)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "sum(increase(litellm_requests_metric_total[1h])) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Запити за годину (розподіл по моделях)",
      "type": "piechart"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "targets": [
        {
          "expr": "sum(increase(litellm_llm_api_failed_requests_metric_total[5m])) by (model)",
          "legendFormat": "Fallback {{model}}",
          "refId": "A"
        }
      ],
      "title": "Fallback-події (хмара → local)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",

# ================================================================
# Ultra-Router v5.0 — Змінні середовища
# Скопіюйте цей файл: cp .env.example .env.ultra-router
# НІКОЛИ не комітьте .env.ultra-router в репозиторій!
# ================================================================

# ── API ключі (обов'язково) ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Groq — 2 незалежних ключі для подвоєного rate-limit
GROQ_API_KEY_1=your_groq_key_1_here
GROQ_API_KEY_2=your_groq_key_2_here

# Mistral — 2 незалежних ключі для load balancing
MISTRAL_API_KEY_1=your_mistral_key_1_here
MISTRAL_API_KEY_2=your_mistral_key_2_here

# ── Захист роутера ───────────────────────────────────────────────
# Використовується як Bearer token для всіх запитів до роутера
# Генерація: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-predator-ultra-router-change-me

# ── PostgreSQL для логування запитів ────────────────────────────
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=litellm
DATABASE_URL=postgresql://litellm:change_me_strong_password@postgres:5432/litellm

# ── Grafana ──────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=predator2026_change_me

# ── Ollama (локальний NVIDIA сервер) — зазвичай не потрібно ─────
# OLLAMA_BASE_URL=http://194.177.1.240:11434

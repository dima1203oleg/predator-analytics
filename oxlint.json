{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "rules": {
    "no-unused-vars": "error",
    "no-undef": "error",
    "no-const-assign": "error",
    "no-dupe-keys": "error",
    "no-dupe-class-members": "error",
    "no-duplicate-case": "error",
    "no-empty-pattern": "error",
    "no-ex-assign": "error",
    "no-fallthrough": "error",
    "no-func-assign": "error",
    "no-import-assign": "error",
    "no-inner-declarations": "error",
    "no-invalid-regexp": "error",
    "no-irregular-whitespace": "error",
    "no-loss-of-precision": "error",
    "no-new-symbol": "error",
    "no-obj-calls": "error",
    "no-prototype-builtins": "warn",
    "no-self-assign": "error",
    "no-setter-return": "error",
    "no-sparse-arrays": "error",
    "no-this-before-super": "error",
    "no-unreachable": "error",
    "no-unsafe-finally": "error",
    "no-unsafe-negation": "error",
    "no-unsafe-optional-chaining": "error",
    "use-isnan": "error",
    "valid-typeof": "error",
    "no-debugger": "error",
    "no-console": "warn",
    "no-empty": "warn",
    "no-extra-boolean-cast": "warn",
    "no-extra-semi": "warn",
    "no-global-assign": "error",
    "no-redeclare": "error",
    "no-shadow-restricted-names": "error",
    "no-unused-labels": "warn",
    "no-useless-catch": "warn",
    "no-useless-escape": "warn",
    "no-with": "error",
    "require-yield": "error",
    "no-compare-neg-zero": "error",
    "no-cond-assign": "error",
    "no-constant-condition": "warn",
    "no-control-regex": "warn",
    "no-delete-var": "error",
    "no-empty-character-class": "error",
    "no-case-declarations": "error",
    "no-class-assign": "error",
    "no-async-promise-executor": "error",
    "no-misleading-character-class": "warn",
    "no-var": "error",
    "prefer-const": "error",
    "prefer-rest-params": "warn",
    "prefer-spread": "warn",
    "default-case-last": "warn",
    "eqeqeq": "warn",
    "no-array-constructor": "warn",
    "no-lonely-if": "warn",
    "no-nested-ternary": "warn",
    "no-object-constructor": "warn",
    "prefer-exponentiation-operator": "warn",
    "prefer-numeric-literals": "warn",
    "prefer-object-spread": "warn",
    "no-useless-computed-key": "warn",
    "no-caller": "error",
    "no-eval": "error",
    "no-extend-native": "error",
    "no-extra-bind": "warn",
    "no-implied-eval": "error",
    "no-iterator": "error",
    "no-labels": "error",
    "no-lone-blocks": "warn",
    "no-loop-func": "warn",
    "no-multi-str": "warn",
    "no-new": "warn",
    "no-new-func": "error",
    "no-new-wrappers": "error",
    "no-octal": "error",
    "no-octal-escape": "error",
    "no-proto": "error",
    "no-return-assign": "warn",
    "no-script-url": "error",
    "no-self-compare": "warn",
    "no-sequences": "warn",
    "no-throw-literal": "error",
    "no-unmodified-loop-condition": "warn",
    "no-unused-expressions": "warn",
    "no-useless-call": "warn",
    "no-useless-concat": "warn",
    "no-useless-return": "warn",
    "no-void": "warn",
    "prefer-promise-reject-errors": "warn",
    "radix": "warn",
    "no-alert": "warn",
    "no-empty-static-block": "warn",
    "no-explicit-any": "warn",
    "no-non-null-assertion": "warn",
    "prefer-ts-expect-error": "warn",
    "no-namespace": "error",
    "prefer-as-const": "warn",
    "no-extra-non-null-assertion": "error",
    "no-misused-new": "error",
    "no-this-alias": "warn",
    "no-unnecessary-type-constraint": "warn",
    "no-unsafe-declaration-merging": "error",
    "no-var-requires": "error",
    "prefer-for-of": "warn",
    "prefer-function-type": "warn",
    "prefer-literal-enum-member": "warn",
    "jsx-key": "error",
    "jsx-no-comment-textnodes": "warn",
    "jsx-no-duplicate-props": "error",
    "jsx-no-target-blank": "error",
    "jsx-no-undef": "error",
    "jsx-no-useless-fragment": "warn",
    "no-children-prop": "warn",
    "no-danger-with-children": "error",
    "no-direct-mutation-state": "error",
    "no-find-dom-node": "warn",
    "no-is-mounted": "error",
    "no-render-return-value": "error",
    "no-string-refs": "error",
    "no-unescaped-entities": "warn",
    "require-render-return": "error",
    "void-dom-elements-no-children": "error",
    "checked-requires-onchange-or-readonly": "warn",
    "iframe-missing-sandbox": "warn",
    "no-unknown-property": "error",
    "rules-of-hooks": "error",
    "exhaustive-deps": "warn",
    "alt-text": "warn",
    "anchor-has-content": "warn",
    "anchor-is-valid": "warn",
    "aria-activedescendant-has-tabindex": "warn",
    "aria-props": "error",
    "aria-proptypes": "error",
    "aria-role": "error",
    "aria-unsupported-elements": "error",
    "click-events-have-key-events": "warn",
    "heading-has-content": "warn",
    "html-has-lang": "warn",
    "iframe-has-title": "warn",
    "img-redundant-alt": "warn",
    "interactive-supports-focus": "warn",
    "label-has-associated-control": "warn",
    "lang": "error",
    "mouse-events-have-key-events": "warn",
    "no-access-key": "warn",
    "no-aria-hidden-on-focusable": "error",
    "no-distracting-elements": "error",
    "no-redundant-roles": "warn",
    "role-has-required-aria-props": "error",
    "role-supports-aria-props": "error",
    "scope": "error",
    "tabindex-no-positive": "warn",
    "export": "error",
    "named": "error",
    "namespace": "error",
    "no-cycle": "warn",
    "no-duplicates": "error",
    "no-self-import": "error",
    "no-named-as-default": "warn",
    "no-named-as-default-member": "warn",
    "no-deprecated": "warn",
    "no-instanceof-array": "error",
    "no-thenable": "error",
    "no-typeof-undefined": "warn",
    "no-useless-fallback-in-spread": "warn",
    "no-useless-length-check": "warn",
    "no-useless-promise-resolve-reject": "warn",
    "no-useless-spread": "warn",
    "prefer-array-find": "warn",
    "prefer-array-flat": "warn",
    "prefer-array-flat-map": "warn",
    "prefer-array-index-of": "warn",
    "prefer-array-some": "warn",
    "prefer-blob-reading-methods": "warn",
    "prefer-code-point": "warn",
    "prefer-date-now": "warn",
    "prefer-dom-node-append": "warn",
    "prefer-dom-node-dataset": "warn",
    "prefer-dom-node-remove": "warn",
    "prefer-dom-node-text-content": "warn",
    "prefer-includes": "warn",
    "prefer-keyboard-event-key": "warn",
    "prefer-logical-operator-over-ternary": "warn",
    "prefer-modern-dom-apis": "warn",
    "prefer-modern-math-apis": "warn",
    "prefer-native-coercion-functions": "warn",
    "prefer-negative-index": "warn",
    "prefer-node-protocol": "warn",
    "prefer-number-properties": "warn",
    "prefer-optional-catch-binding": "warn",
    "prefer-prototype-methods": "warn",
    "prefer-reflect-apply": "warn",
    "prefer-regexp-test": "warn",
    "prefer-set-size": "warn",
    "prefer-string-replace-all": "warn",
    "prefer-string-slice": "warn",
    "prefer-string-starts-ends-with": "warn",
    "prefer-string-trim-start-end": "warn",
    "prefer-type-error": "warn",
    "require-number-to-fixed-digits-argument": "warn",
    "throw-new-error": "warn",
    "no-new-statics": "error",
    "no-return-in-finally": "error",
    "param-names": "warn",
    "valid-params": "error",
    "expect-expect": "warn",
    "no-conditional-expect": "warn",
    "no-disabled-tests": "warn",
    "no-focused-tests": "error",
    "valid-describe-callback": "error",
    "valid-expect": "error",
    "api-keys": "error"
  },
  "settings": {
    "jsx-a11y": {
      "polymorphicPropName": "as",
      "components": {
        "Button": "button",
        "Link": "a",
        "Image": "img",
        "Input": "input"
      }
    }
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    "*.min.js",
    "*.bundle.js",
    "coverage",
    ".git",
    "*.d.ts"
  ],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "globals": {
    "React": "readonly",
    "JSX": "readonly"
  }
}

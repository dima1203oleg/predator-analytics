# Environment variables for NVIDIA server deployment
# Replace SERVER_IP with actual NVIDIA server IP address

# Frontend URLs for CORS
FRONTEND_URL=http://SERVER_IP:8082
FRONTEND_DEV_URL=http://SERVER_IP:3000

# Database URLs for remote access
DATABASE_URL=postgresql+asyncpg://predator:predator_password@SERVER_IP:5432/predator_db
POSTGRES_URL=postgresql://predator:predator_password@SERVER_IP:5432/predator_db

# Service URLs for remote access
OPENSEARCH_URL=http://SERVER_IP:9200
QDRANT_URL=http://SERVER_IP:6333
MLFLOW_URL=http://SERVER_IP:5000
REDIS_URL=redis://SERVER_IP:6379/0

# Backend API URL
BACKEND_URL=http://SERVER_IP:8000

# Frontend Vite proxy targets
VITE_API_URL=http://SERVER_IP:8000/api/v1
VITE_BACKEND_PROXY_TARGET=http://SERVER_IP:8000

# ArgoCD for remote deployment
ARGOCD_SERVER=https://argocd.SERVER_IP
ARGOCD_URL=https://argocd.SERVER_IP

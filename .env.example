# 🦅 PREDATOR Analytics v4.1 — Canonical Configuration Template
# Копіювати в .env та налаштувати. НЕ КОММІТИТИ реальні секрети!

# ── Загальні (Core) ──────────────────────────────────────────
# development, testing, staging, production
ENVIRONMENT=development
# Мінімум 32 символи: openssl rand -hex 32
SECRET_KEY=dev-secret-key-minimum-32-characters-required-for-v41!!
DEBUG=true
APP_VERSION=4.1.0

# ── База даних (PostgreSQL + asyncpg) ─────────────────────────
# Формат: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://predator:devpassword@localhost:5432/predator
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Кешування та Черги (Redis) ───────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ── Графова БД (Neo4j) ────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpassword

# ── Пошук та Вектори (OpenSearch / Qdrant) ───────────────────
OPENSEARCH_URL=http://localhost:9200
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=predator_knowledge

# ── AI Gateway (LiteLLM) ──────────────────────────────────────
LITELLM_GATEWAY_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-dummy-key-for-local-dev

# ── Auth (Keycloak) ───────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=predator
KEYCLOAK_CLIENT_ID=predator-api

# ── Моніторинг (MLflow / Prometheus) ──────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
PROMETHEUS_PORT=9090

# ── Зовнішні API (OSINT) ──────────────────────────────────────
PROZORRO_API_URL=https://public.api.openprocurement.org/api/2.5
EDR_API_URL=https://data.gov.ua/api/3/action
NBU_API_URL=https://bank.gov.ua/NBUStatService/v1
CUSTOMS_API_URL=https://cabinet.customs.gov.ua/api

# Predator Analytics v23.0 - Orchestrator Environment Variables

# ============================================================================
# LLM COUNCIL FREE APIS
# ============================================================================
# Get your keys from:
# Gemini: https://aistudio.google.com/app/apikey
# Groq: https://console.groq.com/keys
# DeepSeek: https://platform.deepseek.com/api_keys

GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
DEEPSEEK_API_KEY=  # Optional - will use Ollama as fallback

# ============================================================================
# TELEGRAM BOT (Get from @BotFather)
# ============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id  # Get from @userinfobot

# ============================================================================
# EXISTING VARS (Keep these)
# ============================================================================
DATABASE_URL=postgresql://predator:predator_password@postgres:5432/predator_db
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
OPENSEARCH_URL=http://opensearch:9200
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=predator_admin
MINIO_SECRET_KEY=predator_secret_key

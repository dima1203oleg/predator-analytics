# ============================================
# TELEGRAM BOT V4.0 - CONFIGURATION TEMPLATE
# ============================================

# ==================== TELEGRAM ====================
# Отримайте токен від @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ваш Telegram ID (отримайте від @userinfobot)
TELEGRAM_ADMIN_ID=1020504147

# ==================== REDIS ====================
# Redis для зберігання контексту розмов
REDIS_URL=redis://localhost:6379/1

# Redis password (якщо потрібен)
# REDIS_PASSWORD=your_redis_password

# ==================== AI MODELS ====================
# Google Gemini API (безкоштовно)
# Отримайте на: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Groq API (безкоштовно)
# Отримайте на: https://console.groq.com
GROQ_API_KEY=

# OpenAI API (платно)
# OPENAI_API_KEY=

# Anthropic Claude API (платно)
# ANTHROPIC_API_KEY=

# ==================== SYSTEM ====================
# Рівень логування: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Шлях до логів
LOG_FILE=telegram_bot_v4.log

# Максимальний розмір логу (MB)
LOG_MAX_SIZE=100

# ==================== DATABASE ====================
# PostgreSQL (якщо використовується)
# DATABASE_URL=postgresql://user:password@localhost:5432/predator

# ==================== MONITORING ====================
# Prometheus
# PROMETHEUS_URL=http://localhost:9090

# Grafana
# GRAFANA_URL=http://localhost:3000

# ==================== KUBERNETES ====================
# Kubernetes config path
# KUBECONFIG=/path/to/kubeconfig

# Default namespace
# K8S_NAMESPACE=default

# ==================== DOCKER ====================
# Docker socket
# DOCKER_SOCKET=unix:///var/run/docker.sock

# ==================== NOTIFICATIONS ====================
# Email notifications (опціонально)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ==================== SECURITY ====================
# Дозволені користувачі (через кому)
# ALLOWED_USERS=123456789,987654321

# Webhook secret (якщо використовується webhook mode)
# WEBHOOK_SECRET=your_secret_key

# ==================== FEATURES ====================
# Увімкнути AI функції (true/false)
ENABLE_AI=true

# Увімкнути Docker контроль (true/false)
ENABLE_DOCKER=true

# Увімкнути Kubernetes контроль (true/false)
ENABLE_K8S=false

# Увімкнути моніторинг (true/false)
ENABLE_MONITORING=true

# ==================== ADVANCED ====================
# Максимальна кількість повідомлень в історії
MAX_CONVERSATION_HISTORY=50

# Час життя контексту (секунди)
CONTEXT_TTL=86400

# Таймаут для AI запитів (секунди)
AI_TIMEOUT=30

# Максимальна довжина відповіді AI (символи)
AI_MAX_RESPONSE_LENGTH=4000

# ==================== WEBHOOK MODE ====================
# Використовувати webhook замість polling (true/false)
USE_WEBHOOK=false

# Webhook URL (якщо USE_WEBHOOK=true)
# WEBHOOK_URL=https://your-domain.com

# Webhook port
# WEBHOOK_PORT=8443

# ==================== RATE LIMITING ====================
# Максимум запитів на користувача за хвилину
RATE_LIMIT_PER_MINUTE=30

# Максимум AI запитів на користувача за годину
AI_RATE_LIMIT_PER_HOUR=100

# ==================== CUSTOM SETTINGS ====================
# Додайте ваші власні налаштування тут

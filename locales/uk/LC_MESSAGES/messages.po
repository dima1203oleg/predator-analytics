#: app/services/voice_service.py:25
msgid "Voice service initialized successfully."
msgstr "Голосовий сервіс успішно ініціалізовано."

#: app/services/voice_service.py:30
msgid "Google Cloud credentials not found."
msgstr "Облікові дані Google Cloud не знайдено."

#: app/services/voice_service.py:45
msgid "Synthesizing text to speech..."

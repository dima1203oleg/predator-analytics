#: app/services/voice_service.py:60
msgid "Text synthesized and saved to file."
msgstr "Текст синтезовано та збережено у файл."

#: app/services/voice_service.py:75
msgid "Recognizing speech from audio file..."
msgstr "Розпізнавання мовлення з аудіофайлу..."

#: app/services/voice_service.py:90
msgid "Speech recognition completed."
msgstr "Розпізнавання мовлення завершено."

#: main.py:15
msgid "Starting Predator Voice Server..."
msgstr "Запуск голосового сервера Predator..."

#: main.py:25
msgid "Server is running on port 8080."
msgstr "Сервер працює на порту 8080."

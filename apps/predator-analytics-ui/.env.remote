# PREDATOR Analytics Frontend - Remote Server Configuration
# ═════════════════════════════════════════════════════════════════

# Backend API (Remote NVIDIA Server)
VITE_API_URL=http://192.168.0.199:8000/api/v1
VITE_V45_API_URL=http://192.168.0.199:8000/api/v45

# Backend Proxy (for development)
VITE_BACKEND_PROXY_TARGET=http://192.168.0.199:8000

# WebSocket (Real-time updates from remote backend)
VITE_WS_URL=ws://192.168.0.199:8000/ws

# LiteLLM Gateway (AI Services on remote server)
VITE_LITELLM_URL=http://192.168.0.199:4000
VITE_LITELLM_KEY=predator-litellm-secret

# OpenSearch (for full-text search)
VITE_OPENSEARCH_URL=http://192.168.0.199:9200

# Qdrant (for vector similarity search)
VITE_QDRANT_URL=http://192.168.0.199:6333

# Ollama (for local AI models on remote GPU)
VITE_OLLAMA_URL=http://192.168.0.199:11434

# Environment mode
VITE_ENV=production
VITE_MODE=remote

# Feature flags
VITE_ENABLE_MOCK_API=false
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_TELEMETRY=false

# UI Configuration
VITE_APP_TITLE=PREDATOR Analytics v56.1 (Remote)
VITE_APP_VERSION=56.1.0
VITE_LANGUAGE=uk

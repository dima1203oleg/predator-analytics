{"type":"frame-snapshot","snapshot":{"callId":"call@8","snapshotName":"after@call@8","pageId":"page@d4ed024bfdbe1aca626fd8c5bc707f64","frameId":"frame@03d042d9cab2508aca52f811735556e6","frameUrl":"http://localhost:3030/admin/command?tab=infra","doctype":"html","html":["HTML",{"lang":"uk","data-op-mode":"sovereign","class":"high-visibility","style":"--op-accent: rgb(212, 175, 55); --op-accent-soft: rgba(212, 175, 55, 0.18); --op-accent-glow: 0 0 45px rgba(212, 175, 55, 0.3); --op-accent-border: rgba(212, 175, 55, 0.45); --op-accent-text: #fde68a; --op-accent-bg: rgba(212, 175, 55, 0.12); --op-header-glow: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.2), transparent); --op-sidebar-active: linear-gradient(135deg, rgba(212, 175, 55, 0.15), rgba(220, 38, 38, 0.1)); --op-pulse-color: rgba(212, 175, 55, 0.7); --op-scanline: rgba(212, 175, 55, 0.04); --op-ring: rgba(212, 175, 55, 0.25);"},["HEAD",{},["BASE",{"href":"http://localhost:3030/admin/command?tab=infra"}],"\n    ","\n\n    ","\n\n    ",["META",{"charset":"utf-8"}],"\n    ",["LINK",{"rel":"icon","type":"image/svg+xml","href":"/vite.svg"}],"\n    ",["META",{"name":"viewport","content":"width=device-width, initial-scale=1.0, viewport-fit=cover"}],"\n    ",["META",{"name":"theme-color","content":"#020202"}],"\n    ",["META",{"name":"apple-mobile-web-app-capable","content":"yes"}],"\n    ",["META",{"name":"apple-mobile-web-app-status-bar-style","content":"black-translucent"}],"\n    ",["TITLE",{},"PREDATOR v66.0-ELITE | Суверенна Аналітична Платформа"],"\n    ",["META",{"name":"description","content":"Суверенна безсерверна архітектура // ШІ-рішення для митної розвідки та аналітики v66.0"}],"\n    ","\n    ",["STYLE",{},"\n      html, body { margin: 0; padding: 0; background: #050608; cursor: default; }\n      #root:empty {\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        height: 100vh;\n        width: 100vw;\n        background: #000000;\n      }\n    "],"\n  ",["STYLE",{},".float-tooltip-kap {\n  position: absolute;\n  width: max-content; /* prevent shrinking near right edge */\n  max-width: max(50%, 150px);\n  padding: 3px 5px;\n  border-radius: 3px;\n  font: 12px sans-serif;\n  color: #eee;\n  background: rgba(0,0,0,0.6);\n  pointer-events: none;\n}\n"],["STYLE",{},".force-graph-container canvas {\n  display: block;\n  user-select: none;\n  outline: none;\n  -webkit-tap-highlight-color: transparent;\n}\n\n.force-graph-container .clickable {\n  cursor: pointer;\n}\n\n.force-graph-container .grabbable {\n  cursor: move;\n  cursor: grab;\n  cursor: -moz-grab;\n  cursor: -webkit-grab;\n}\n\n.force-graph-container .grabbable:active {\n  cursor: grabbing;\n  cursor: -moz-grabbing;\n  cursor: -webkit-grabbing;\n}\n"],["STYLE",{},"@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Syne:wght@600;700;800&display=swap');\n\n/* Канонічні дизайн-токени — єдине джерело істини */\n\n/* ============================================================================\n   PREDATOR ELITE SPEC v2.0 — DESIGN TOKENS — ЄДИНЕ ДЖЕРЕЛО ІСТИНИ\n   Military Cyberpunk Dark UI | Sovereign Command Center\n   Відповідає §8 PREDATOR_ELITE_SPEC_v56.5.md\n   ============================================================================ */\n\n:root {\n  /* ── SPACING SCALE ── (8px base) */\n  --space-0: 0;\n  --space-1: 0.25rem;   /*  4px */\n  --space-2: 0.5rem;    /*  8px */\n  --space-3: 0.75rem;   /* 12px */\n  --space-4: 1rem;      /* 16px */\n  --space-5: 1.25rem;   /* 20px */\n  --space-6: 1.5rem;    /* 24px */\n  --space-8: 2rem;      /* 32px */\n  --space-10: 2.5rem;   /* 40px */\n  --space-12: 3rem;     /* 48px */\n  --space-16: 4rem;     /* 64px */\n\n  /* ── BORDER RADIUS ── */\n  --radius-sm: 0.375rem;\n  --radius-md: 0.5rem;\n  --radius-lg: 0.75rem;\n  --radius-xl: 1rem;\n  --radius-2xl: 1.5rem;\n  --radius-3xl: 2rem;\n  --radius-full: 9999px;\n\n  /* ── SEMANTIC BACKGROUNDS — матова безодня */\n  --bg-canvas: #0a0a0a;\n  --bg-surface: #0d0d0d;\n  --bg-elevated: #111111;\n  --bg-overlay: rgba(10, 10, 10, 0.97);\n  --bg-panel: rgba(15, 15, 15, 0.95);\n\n  /* ── FOREGROUND ── */\n  --fg-primary: #f8fafc;\n  --fg-secondary: #cbd5e1;\n  --fg-muted: #64748b;\n  --fg-disabled: #334155;\n\n  /* ── BORDERS ── */\n  --border-subtle: rgba(255, 255, 255, 0.05);\n  --border-default: rgba(255, 255, 255, 0.10);\n  --border-strong: rgba(255, 255, 255, 0.20);\n  --border-focus: rgba(99, 102, 241, 0.60);\n\n  /* ── ACCENT PALETTE ── (v64.0-MATTE: стримана небезпека) */\n  --accent-sovereign: #c41230;\n  --accent-sovereign-dim: rgba(196, 18, 48, 0.15);\n  --accent-indigo: #4f52b0;\n  --accent-cyan: #008299;\n  --accent-emerald: #0d7a4a;\n  --accent-amber: #b87a14;\n  --accent-rose: #c41230;\n  --accent-violet: #6d4fb0;\n  --accent-orange: #c44d00;\n  --accent-crimson: #8b1a1a;\n  --accent-blood: #6b0a3a;\n\n  /* ── SIGNAL PALETTE ── (v64.0-MATTE: військові сигнали) */\n  --signal-red: #c41230;\n  --signal-red-dim: rgba(196, 18, 48, 0.5);\n  --signal-green: #0d7a4a;\n  --signal-orange: #c44d00;\n  --signal-yellow: #b89b14;\n  --signal-blue: #2d5f8a;\n\n  /* ── GRID SYSTEM ── (v64.0-MATTE: червона сітка фону) */\n  --grid-color: rgba(180, 25, 40, 0.12);\n  --grid-color-strong: rgba(180, 25, 40, 0.2);\n  --grid-size: 48px;\n  --grid-dot-size: 1.5px;\n\n  /* ── ELEVATION SHADOWS ── */\n  --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.5);\n  --shadow-sm: 0 2px 6px rgba(0, 0, 0, 0.6);\n  --shadow-md: 0 6px 16px rgba(0, 0, 0, 0.7);\n  --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.8);\n  --shadow-xl: 0 20px 60px rgba(0, 0, 0, 0.85);\n  --shadow-2xl: 0 30px 80px rgba(0, 0, 0, 0.9);\n\n  /* ── TYPOGRAPHY — інституційний рівень (аналітика світового масштабу) */\n  --font-sans: 'Plus Jakarta Sans', 'Segoe UI', system-ui, sans-serif;\n  --font-mono: 'IBM Plex Mono', 'JetBrains Mono', ui-monospace, monospace;\n  --font-display: 'Syne', 'Plus Jakarta Sans', system-ui, sans-serif;\n  --font-metric: 'IBM Plex Mono', 'Barlow Condensed', ui-monospace, sans-serif;\n\n  --text-2xs: 0.5rem;     /*  8px */\n  --text-xs: 0.625rem;    /* 10px */\n  --text-sm: 0.75rem;     /* 12px */\n  --text-base: 0.8125rem; /* 13px — density */\n  --text-md: 0.875rem;    /* 14px */\n  --text-lg: 1rem;        /* 16px */\n  --text-xl: 1.25rem;     /* 20px */\n  --text-2xl: 1.5rem;     /* 24px */\n  --text-3xl: 2rem;       /* 32px */\n\n  /* ── TRANSITIONS ── */\n  --ease-default: cubic-bezier(0.4, 0, 0.2, 1);\n  --ease-spring: cubic-bezier(0.23, 1, 0.32, 1);\n  --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);\n  --transition-fast: 150ms var(--ease-default);\n  --transition-normal: 300ms var(--ease-default);\n  --transition-slow: 500ms var(--ease-spring);\n\n  /* ── Z-INDEX SCALE ── */\n  --z-base: 0;\n  --z-dropdown: 100;\n  --z-sticky: 200;\n  --z-sidebar: 300;\n  --z-topbar: 400;\n  --z-modal: 500;\n  --z-popover: 600;\n  --z-tooltip: 700;\n  --z-toast: 800;\n  --z-overlay: 900;\n  --z-max: 9999;\n\n  /* ── SIDEBAR ── */\n  --sidebar-width-open: 280px;\n  --sidebar-width-closed: 72px;\n  --topbar-height: 56px;\n  --statusbar-height: 24px;\n\n  /* ── AMBIENT GLOW BACKGROUNDS ── (Spec v2.0: Sovereign Cyan домінує) */\n  --ambient-sovereign: radial-gradient(circle at 50% 0%, rgba(0, 245, 255, 0.06), transparent 55%);\n  --ambient-emerald: radial-gradient(circle at 20% 80%, rgba(16, 185, 129, 0.10), transparent 50%);\n  --ambient-cyan: radial-gradient(circle at 80% 20%, rgba(0, 245, 255, 0.08), transparent 50%);\n  --ambient-indigo: radial-gradient(circle at 50% 50%, rgba(99, 102, 241, 0.10), transparent 60%);\n  --ambient-amber: radial-gradient(circle at 10% 30%, rgba(245, 158, 11, 0.10), transparent 50%);\n  --ambient-rose: radial-gradient(circle at 90% 70%, rgba(244, 63, 94, 0.08), transparent 50%);\n  --ambient-violet: radial-gradient(circle at 60% 10%, rgba(139, 92, 246, 0.10), transparent 50%);\n\n  /* ── CARD SURFACE SYSTEM ── */\n  --surface-0: rgba(0, 0, 0, 0.96);\n  --surface-1: rgba(3, 3, 6, 0.92);\n  --surface-2: rgba(6, 6, 12, 0.85);\n  --surface-3: rgba(10, 10, 18, 0.75);\n  --surface-hover: rgba(255, 23, 68, 0.04);\n  --surface-active: rgba(255, 23, 68, 0.08);\n\n  /* ── MATTE SURFACES ── (v64.0: без скляних ефектів) */\n  --matte-bg: rgba(20, 20, 22, 0.95);\n  --matte-bg-elevated: rgba(28, 28, 30, 0.97);\n  --matte-border: 1px solid rgba(255, 255, 255, 0.06);\n  --matte-border-strong: 1px solid rgba(255, 255, 255, 0.1);\n\n  /* ── MATTE GRADIENTS ── (v64.0: стримані переходи) */\n  --matte-gradient-dark: linear-gradient(180deg, rgba(15,15,15,1) 0%, rgba(10,10,10,1) 100%);\n  --matte-gradient-red: linear-gradient(180deg, rgba(25,8,8,1) 0%, rgba(15,10,10,1) 100%);\n  --matte-gradient-warm: linear-gradient(180deg, rgba(25,12,5,1) 0%, rgba(15,10,8,1) 100%);\n\n  /* ── STATUS COLORS ── */\n  --status-ok: #10b981;\n  --status-ok-bg: rgba(16, 185, 129, 0.12);\n  --status-ok-border: rgba(16, 185, 129, 0.25);\n  --status-warn: #fb7185;\n  --status-warn-bg: rgba(251, 113, 133, 0.12);\n  --status-warn-border: rgba(251, 113, 133, 0.25);\n  --status-error: #f43f5e;\n  --status-error-bg: rgba(244, 63, 94, 0.12);\n  --status-error-border: rgba(244, 63, 94, 0.25);\n  --status-info: #3b82f6;\n  --status-info-bg: rgba(59, 130, 246, 0.12);\n  --status-info-border: rgba(59, 130, 246, 0.25);\n  --status-neutral: #64748b;\n  --status-neutral-bg: rgba(100, 116, 139, 0.10);\n  --status-neutral-border: rgba(100, 116, 139, 0.20);\n\n  /* ── ANIMATED SHIMMER ── */\n  --shimmer-gradient: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.06) 50%, transparent 100%);\n  --shimmer-speed: 2s;\n\n  /* ── ASSETS ── */\n  --noise-texture: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n}\n\n/* Консолідовані візуальні ефекти (замість inline <style>) */\n\n/* ============================================================================\n   PREDATOR v63.0-ELITE — PREMIUM VISUAL EFFECTS\n   Консолідація всіх inline <style> блоків з 21+ компонентів.\n   Імпортується один раз у index.css.\n   ============================================================================ */\n\n/* ── PANEL 3D ── */\n\n.panel-3d {\n  transform: perspective(1000px) rotateX(0deg);\n  transition: all 0.5s var(--ease-spring, cubic-bezier(0.23, 1, 0.32, 1));\n}\n\n.panel-3d:hover {\n  transform: perspective(1000px) rotateX(1deg) translateY(-4px);\n  box-shadow:\n    0 24px 64px -12px rgba(0, 0, 0, 0.7),\n    0 0 30px rgba(99, 102, 241, 0.1);\n}\n\n/* ── SCROLLBAR — Єдина версія для всього проекту ── */\n\n.scrollbar-predator::-webkit-scrollbar {\n  width: 4px;\n  height: 4px;\n}\n\n.scrollbar-predator::-webkit-scrollbar-track {\n  background: transparent;\n}\n\n.scrollbar-predator::-webkit-scrollbar-thumb {\n  background: rgba(99, 102, 241, 0.2);\n  border-radius: 9999px;\n}\n\n.scrollbar-predator::-webkit-scrollbar-thumb:hover {\n  background: rgba(99, 102, 241, 0.4);\n}\n\n/* ── SCROLLBAR DARK — Blood Red Elite ── */\n\n.scrollbar-dark::-webkit-scrollbar {\n  width: 4px;\n}\n\n.scrollbar-dark::-webkit-scrollbar-track {\n  background: transparent;\n}\n\n.scrollbar-dark::-webkit-scrollbar-thumb {\n  background: rgba(225, 29, 72, 0.3);\n  border-radius: 10px;\n}\n\n.scrollbar-dark::-webkit-scrollbar-thumb:hover {\n  background: rgba(225, 29, 72, 0.6);\n}\n\n/* Варіанти кольору скролбару */\n\n.scrollbar-cyan::-webkit-scrollbar-thumb {\n  background: rgba(6, 182, 212, 0.2);\n}\n\n.scrollbar-cyan::-webkit-scrollbar-thumb:hover {\n  background: rgba(6, 182, 212, 0.4);\n}\n\n.scrollbar-emerald::-webkit-scrollbar-thumb {\n  background: rgba(16, 185, 129, 0.2);\n}\n\n.scrollbar-emerald::-webkit-scrollbar-thumb:hover {\n  background: rgba(16, 185, 129, 0.4);\n}\n\n/* ── SKEW TEXT ── */\n\n.skew-text {\n  transform: skewX(-4deg);\n}\n\n/* ── TACTICAL GLOW UTILITIES ── */\n\n.tactical-glow-indigo  { box-shadow: var(--glow-indigo); }\n\n.tactical-glow-cyan    { box-shadow: var(--glow-cyan); }\n\n.tactical-glow-rose    { box-shadow: var(--glow-rose); }\n\n.tactical-glow-emerald { box-shadow: var(--glow-emerald); }\n\n.tactical-glow-amber   { box-shadow: var(--glow-amber); }\n\n.tactical-glow-violet  { box-shadow: var(--glow-violet); }\n\n/* ── CARD HOVER LIFT ── */\n\n.card-hover-lift {\n  transition: all 0.3s var(--ease-default, cubic-bezier(0.4, 0, 0.2, 1));\n}\n\n.card-hover-lift:hover {\n  transform: translateY(-4px);\n  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5);\n  border-color: rgba(255, 255, 255, 0.15);\n}\n\n/* ── SIDEBAR ACTIVE ITEM ── */\n\n.sidebar-nav-active {\n  background: linear-gradient(135deg, rgba(99, 102, 241, 0.12) 0%, rgba(6, 182, 212, 0.06) 100%);\n  border: 1px solid rgba(99, 102, 241, 0.20);\n  box-shadow:\n    0 0 20px rgba(99, 102, 241, 0.08),\n    inset 0 1px 0 rgba(255, 255, 255, 0.04);\n}\n\n/* ── GRADIENT HEADINGS ── */\n\n.gradient-text-indigo {\n  background: linear-gradient(135deg, #ffffff 0%, #c7d2fe 50%, #818cf8 100%);\n  -webkit-background-clip: text;\n  background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n\n.gradient-text-cyan {\n  background: linear-gradient(135deg, #ffffff 0%, #a5f3fc 50%, #06b6d4 100%);\n  -webkit-background-clip: text;\n  background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n\n.gradient-text-orange {\n  background: linear-gradient(135deg, #ffffff 0%, #fed7aa 50%, #fb923c 100%);\n  -webkit-background-clip: text;\n  background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n\n.gradient-text-rose {\n  background: linear-gradient(135deg, #ffffff 0%, #fecdd3 50%, #f43f5e 100%);\n  -webkit-background-clip: text;\n  background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n\n/* ── NEON BORDERS ── */\n\n.neon-border-indigo {\n  border-color: rgba(99, 102, 241, 0.5);\n  box-shadow: 0 0 15px rgba(99, 102, 241, 0.15), inset 0 0 15px rgba(99, 102, 241, 0.04);\n}\n\n.neon-border-cyan {\n  border-color: rgba(6, 182, 212, 0.5);\n  box-shadow: 0 0 15px rgba(6, 182, 212, 0.15), inset 0 0 15px rgba(6, 182, 212, 0.04);\n}\n\n.neon-border-orange {\n  border-color: rgba(249, 115, 22, 0.5);\n  box-shadow: 0 0 15px rgba(249, 115, 22, 0.15), inset 0 0 15px rgba(249, 115, 22, 0.04);\n}\n\n.neon-border-rose {\n  border-color: rgba(244, 63, 94, 0.5);\n  box-shadow: 0 0 15px rgba(244, 63, 94, 0.15), inset 0 0 15px rgba(244, 63, 94, 0.04);\n}\n\n.neon-border-violet {\n  border-color: rgba(139, 92, 246, 0.5);\n  box-shadow: 0 0 15px rgba(139, 92, 246, 0.15), inset 0 0 15px rgba(139, 92, 246, 0.04);\n}\n\n/* ── FACTORY ANIMATIONS ── */\n\n@keyframes factory-glow {\n  0%, 100% {\n    box-shadow: 0 0 20px rgba(249, 115, 22, 0.2), 0 0 60px rgba(249, 115, 22, 0.1);\n  }\n  50% {\n    box-shadow: 0 0 40px rgba(249, 115, 22, 0.4), 0 0 80px rgba(249, 115, 22, 0.15);\n  }\n}\n\n.factory-pulse {\n  animation: factory-glow 3s ease-in-out infinite;\n}\n\n@keyframes pipeline-flow {\n  0%   { background-position: 0% 50%; }\n  50%  { background-position: 100% 50%; }\n  100% { background-position: 0% 50%; }\n}\n\n.pipeline-flow {\n  background: linear-gradient(90deg, #f97316, #f59e0b, #06b6d4, #f97316);\n  background-size: 300% 300%;\n  animation: pipeline-flow 3s ease infinite;\n}\n\n/* ── AZR PULSE ── */\n\n@keyframes azr-pulse {\n  0%, 100% {\n    opacity: 1;\n    filter: drop-shadow(0 0 4px rgba(249, 115, 22, 0.6));\n  }\n  50% {\n    opacity: 0.7;\n    filter: drop-shadow(0 0 12px rgba(249, 115, 22, 0.9));\n  }\n}\n\n.azr-active {\n  animation: azr-pulse 2s ease-in-out infinite;\n}\n\n/* ── STATUS DOT ── */\n\n.status-dot {\n  position: relative;\n}\n\n.status-dot::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  border-radius: 9999px;\n  opacity: 0.5;\n  filter: blur(4px);\n  animation: pulse 2s ease-in-out infinite;\n  background: inherit;\n}\n\n/* ── DATA CAPSULE ── */\n\n.data-capsule-enhanced {\n  background: linear-gradient(135deg, rgba(15, 23, 42, 0.8) 0%, rgba(2, 6, 23, 0.9) 100%);\n  border: 1px solid rgba(255, 255, 255, 0.05);\n  box-shadow:\n    0 4px 20px rgba(0, 0, 0, 0.5),\n    inset 0 1px 1px rgba(255, 255, 255, 0.05);\n  transition: all 0.3s var(--ease-default, cubic-bezier(0.4, 0, 0.2, 1));\n}\n\n.data-capsule-enhanced:hover {\n  border-color: rgba(6, 182, 212, 0.3);\n  box-shadow:\n    0 8px 32px rgba(6, 182, 212, 0.1),\n    inset 0 1px 1px rgba(255, 255, 255, 0.1);\n}\n\n/* ============================================================================\n   PREDATOR v57 NEXUS — NEW CORE EFFECTS\n   ============================================================================ */\n\n/* ── NEXUS HUD CORNERS ── */\n\n.hud-corner-nexus {\n  position: absolute;\n  width: 12px;\n  height: 12px;\n  pointer-events: none;\n  z-index: 30;\n  transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);\n  opacity: 0.6;\n}\n\n.group:hover .hud-corner-nexus {\n  opacity: 1;\n  width: 16px;\n  height: 16px;\n}\n\n.hud-corner-tl { top: -1px; left: -1px; border-top: 2px solid var(--hud-accent, var(--neon-cyan)); border-left: 2px solid var(--hud-accent, var(--neon-cyan)); }\n\n.hud-corner-tr { top: -1px; right: -1px; border-top: 2px solid var(--hud-accent, var(--neon-cyan)); border-right: 2px solid var(--hud-accent, var(--neon-cyan)); }\n\n.hud-corner-bl { bottom: -1px; left: -1px; border-bottom: 2px solid var(--hud-accent, var(--neon-cyan)); border-left: 2px solid var(--hud-accent, var(--neon-cyan)); }\n\n.hud-corner-br { bottom: -1px; right: -1px; border-bottom: 2px solid var(--hud-accent, var(--neon-cyan)); border-right: 2px solid var(--hud-accent, var(--neon-cyan)); }\n\n.hud-corner-rose { --hud-accent: #f43f5e; }\n\n.hud-corner-emerald { --hud-accent: #10b981; }\n\n.hud-corner-cyan { --hud-accent: #06b6d4; }\n\n.hud-corner-amber { --hud-accent: #f59e0b; }\n\n/* ── SCANLINE v57 ── */\n\n@keyframes nexus-scan {\n  0% { transform: translateY(-100%); }\n  100% { transform: translateY(200%); }\n}\n\n.scanline-nexus {\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(\n    to bottom,\n    transparent 0%,\n    rgba(0, 243, 255, 0.03) 50%,\n    rgba(0, 243, 255, 0.08) 50.5%,\n    rgba(0, 243, 255, 0.03) 51%,\n    transparent 100%\n  );\n  height: 200%;\n  width: 100%;\n  z-index: 10;\n  pointer-events: none;\n  animation: nexus-scan 8s linear infinite;\n  opacity: 0.4;\n}\n\n/* ── SIDEBAR SCAN SLIDE ── */\n\n@keyframes scan-slide {\n  0% { background-position: 200% 0; }\n  100% { background-position: -200% 0; }\n}\n\n/* ── SIDEBAR KINETIC HOVER ── */\n\n.sidebar-kinetic-item {\n  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);\n}\n\n.sidebar-kinetic-item:hover {\n  transform: translateX(2px);\n}\n\n/* ── GLOW NEON INTENSE ── */\n\n.glow-nexus-cyan {\n  box-shadow: 0 0 30px rgba(0, 243, 255, 0.1), inset 0 0 20px rgba(0, 243, 255, 0.05);\n}\n\n.glow-nexus-cyan:hover {\n  box-shadow: 0 0 50px rgba(0, 243, 255, 0.2), inset 0 0 30px rgba(0, 243, 255, 0.1);\n}\n\n/* ── GLASS HUD BASE ── */\n\n.glass-hud {\n  background: rgba(1, 4, 9, 0.75);\n  backdrop-filter: blur(24px);\n  border: 1px solid rgba(0, 243, 255, 0.15);\n  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);\n}\n\n.glass-hud:hover {\n  border-color: rgba(0, 243, 255, 0.3);\n}\n\n/* ============================================================================\n   PREDATOR v57 — ADVANCED PREMIUM UTILITIES\n   ============================================================================ */\n\n/* ── SHIMMER LOADING SKELETON ── */\n\n@keyframes shimmer-sweep {\n  0% { transform: translateX(-100%); }\n  100% { transform: translateX(100%); }\n}\n\n.skeleton-shimmer {\n  position: relative;\n  overflow: hidden;\n  background: rgba(15, 23, 42, 0.6);\n  border-radius: var(--radius-lg);\n}\n\n.skeleton-shimmer::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.04) 40%, rgba(255, 255, 255, 0.08) 50%, rgba(255, 255, 255, 0.04) 60%, transparent 100%);\n  animation: shimmer-sweep 2s ease-in-out infinite;\n}\n\n/* ── STAT CARD V2 — з динамічним glow ── */\n\n.stat-card-v2 {\n  position: relative;\n  background: var(--surface-1);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius-2xl);\n  padding: 1.25rem;\n  overflow: hidden;\n  transition: all 0.4s var(--ease-spring, cubic-bezier(0.23, 1, 0.32, 1));\n}\n\n.stat-card-v2::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  height: 2px;\n  background: var(--stat-accent, var(--accent-indigo));\n  opacity: 0;\n  transition: opacity 0.3s ease;\n}\n\n.stat-card-v2:hover {\n  border-color: rgba(255, 255, 255, 0.12);\n  transform: translateY(-2px);\n  box-shadow:\n    0 12px 40px rgba(0, 0, 0, 0.4),\n    0 0 0 1px rgba(255, 255, 255, 0.06);\n}\n\n.stat-card-v2:hover::before {\n  opacity: 1;\n}\n\n/* Тонові варіанти stat-card */\n\n.stat-card-v2.tone-emerald { --stat-accent: var(--accent-emerald); }\n\n.stat-card-v2.tone-cyan    { --stat-accent: var(--accent-cyan); }\n\n.stat-card-v2.tone-amber   { --stat-accent: var(--accent-amber); }\n\n.stat-card-v2.tone-rose    { --stat-accent: var(--accent-rose); }\n\n.stat-card-v2.tone-indigo  { --stat-accent: var(--accent-indigo); }\n\n.stat-card-v2.tone-violet  { --stat-accent: var(--accent-violet); }\n\n/* ── AMBIENT MESH SECTION ── */\n\n.ambient-section {\n  position: relative;\n  overflow: hidden;\n}\n\n.ambient-section::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  opacity: 0.6;\n  transition: opacity 0.6s ease;\n  pointer-events: none;\n  z-index: 0;\n}\n\n.ambient-section:hover::before {\n  opacity: 1;\n}\n\n.ambient-section.mesh-primary::before   { background: var(--mesh-primary); }\n\n.ambient-section.mesh-warm::before      { background: var(--mesh-warm); }\n\n.ambient-section.mesh-cool::before      { background: var(--mesh-cool); }\n\n.ambient-section.mesh-threat::before    { background: var(--mesh-threat); }\n\n/* ── PREMIUM CARD DEPTH ── */\n\n.card-depth {\n  background: var(--surface-1);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius-2xl);\n  box-shadow: var(--shadow-md);\n  transition: all 0.35s var(--ease-spring, cubic-bezier(0.23, 1, 0.32, 1));\n  position: relative;\n  overflow: hidden;\n}\n\n.card-depth::after {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  height: 1px;\n  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), transparent);\n}\n\n.card-depth:hover {\n  border-color: var(--border-default);\n  box-shadow: var(--shadow-lg);\n  transform: translateY(-3px);\n}\n\n/* ── INTERACTIVE ICON BUTTON ── */\n\n.icon-btn-glow {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 2.5rem;\n  height: 2.5rem;\n  border-radius: var(--radius-xl);\n  border: 1px solid var(--border-subtle);\n  background: var(--surface-2);\n  transition: all 0.25s ease;\n  cursor: pointer;\n  color: var(--fg-muted);\n}\n\n.icon-btn-glow:hover {\n  border-color: var(--border-default);\n  background: var(--surface-3);\n  color: var(--fg-primary);\n  box-shadow: 0 0 16px rgba(99, 102, 241, 0.12);\n}\n\n/* ── LIVE DOT INDICATOR ── */\n\n@keyframes live-pulse {\n  0%, 100% { opacity: 1; transform: scale(1); }\n  50% { opacity: 0.5; transform: scale(1.8); }\n}\n\n.live-dot {\n  position: relative;\n  width: 8px;\n  height: 8px;\n  border-radius: 9999px;\n  background: var(--accent-emerald);\n}\n\n.live-dot::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  border-radius: 9999px;\n  background: inherit;\n  animation: live-pulse 2s ease-in-out infinite;\n}\n\n/* ── GRADIENT LINE DIVIDER ── */\n\n.divider-gradient {\n  height: 1px;\n  border: none;\n  background: linear-gradient(90deg, transparent, rgba(99, 102, 241, 0.25), rgba(6, 182, 212, 0.15), transparent);\n}\n\n/* ── BADGE v2 ── */\n\n.badge-v2 {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.375rem;\n  padding: 0.25rem 0.75rem;\n  border-radius: var(--radius-full);\n  font-size: 0.625rem;\n  font-weight: 700;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  border: 1px solid transparent;\n  transition: all 0.2s ease;\n}\n\n.badge-v2.badge-emerald {\n  background: var(--status-ok-bg);\n  border-color: var(--status-ok-border);\n  color: #6ee7b7;\n}\n\n.badge-v2.badge-amber {\n  background: var(--status-warn-bg);\n  border-color: var(--status-warn-border);\n  color: #fcd34d;\n}\n\n.badge-v2.badge-rose {\n  background: var(--status-error-bg);\n  border-color: var(--status-error-border);\n  color: #fda4af;\n}\n\n.badge-v2.badge-cyan {\n  background: var(--status-info-bg);\n  border-color: var(--status-info-border);\n  color: #67e8f9;\n}\n\n.badge-v2.badge-indigo, .badge-v2-indigo {\n  background: rgba(99, 102, 241, 0.12);\n  border-color: rgba(99, 102, 241, 0.25);\n  color: #a5b4fc;\n}\n\n/* v11.5 Badge Color Variations — Sovereign Apex Hub */\n\n.badge-v2-emerald { background: var(--status-ok-bg); border-color: var(--status-ok-border); color: #6ee7b7; }\n\n.badge-v2-rose { background: var(--status-error-bg); border-color: var(--status-error-border); color: #fda4af; }\n\n.badge-v2-cyan { background: var(--status-info-bg); border-color: var(--status-info-border); color: #67e8f9; }\n\n.badge-v2-amber { background: var(--status-warn-bg); border-color: var(--status-warn-border); color: #fcd34d; }\n\n.badge-v2-indigo { background: rgba(99, 102, 241, 0.12); border-color: rgba(99, 102, 241, 0.25); color: #a5b4fc; }\n\n/* Glimmer effect for v11.5 Sovereign badges */\n\n.badge-v2-glimmer {\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 50%;\n  height: 100%;\n  background: linear-gradient(\n    90deg,\n    transparent,\n    rgba(255, 255, 255, 0.15),\n    transparent\n  );\n  transform: skewX(-25deg);\n  animation: badge-glimmer-sweep 4s infinite;\n  pointer-events: none;\n}\n\n@keyframes badge-glimmer-sweep {\n  0% { left: -100%; }\n  25% { left: 200%; }\n  100% { left: 200%; }\n}\n\n/* ── CONTENT SECTION HEADER ── */\n\n.section-header-v2 {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 1rem;\n  padding-bottom: 1rem;\n  border-bottom: 1px solid var(--border-subtle);\n  margin-bottom: 1.5rem;\n}\n\n/* ── FLOATING ACTION RING ── */\n\n@keyframes ring-orbit {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n\n.orbit-ring {\n  position: absolute;\n  inset: -4px;\n  border-radius: var(--radius-full);\n  border: 1px dashed rgba(99, 102, 241, 0.15);\n  animation: ring-orbit 20s linear infinite;\n  pointer-events: none;\n}\n\n/* ============================================================================\n   PREDATOR v63.0-ELITE — SOVEREIGN POWER DESIGN SYSTEM\n   Потужні ефекти для основного інтерфейсу\n   ============================================================================ */\n\n/* ── COMMAND TERMINAL CARD — Стиль командного терміналу ── */\n\n.terminal-card {\n  position: relative;\n  background: linear-gradient(180deg, rgba(1, 4, 9, 0.9) 0%, rgba(5, 10, 20, 0.85) 100%);\n  border: 1px solid rgba(255, 255, 255, 0.06);\n  border-radius: 8px;\n  overflow: hidden;\n  box-shadow:\n    0 4px 32px rgba(0, 0, 0, 0.6),\n    inset 0 1px 0 rgba(255, 255, 255, 0.04);\n  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);\n}\n\n.terminal-card::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  height: 2px;\n  background: linear-gradient(90deg, transparent, var(--op-accent, rgba(99, 102, 241, 0.6)), transparent);\n  opacity: 0;\n  transition: opacity 0.4s ease;\n}\n\n.terminal-card:hover::before {\n  opacity: 1;\n}\n\n.terminal-card:hover {\n  border-color: var(--op-accent-border, rgba(255, 255, 255, 0.1));\n  box-shadow:\n    0 8px 48px rgba(0, 0, 0, 0.7),\n    0 0 30px var(--op-accent-bg, rgba(99, 102, 241, 0.06)),\n    inset 0 1px 0 rgba(255, 255, 255, 0.06);\n  transform: translateY(-2px);\n}\n\n/* ── TACTICAL HEADER BAR — Верхня полоса з операційним акцентом ── */\n\n.tactical-header {\n  position: relative;\n  background: linear-gradient(180deg, rgba(1, 4, 9, 0.95) 0%, rgba(2, 6, 15, 0.9) 100%);\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n  backdrop-filter: blur(24px);\n}\n\n.tactical-header::after {\n  content: '';\n  position: absolute;\n  bottom: 0;\n  left: 0;\n  right: 0;\n  height: 1px;\n  background: var(--op-header-glow, linear-gradient(90deg, transparent, rgba(99, 102, 241, 0.15), transparent));\n}\n\n/* ── POWER METRIC — Великий статистичний блок ── */\n\n.power-metric {\n  position: relative;\n  padding: 1.25rem;\n  background: linear-gradient(135deg, rgba(1, 4, 9, 0.8) 0%, rgba(8, 15, 30, 0.7) 100%);\n  border: 1px solid rgba(255, 255, 255, 0.04);\n  border-radius: 12px;\n  overflow: hidden;\n  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);\n}\n\n.power-metric::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: radial-gradient(ellipse at 30% 0%, var(--op-accent-bg, rgba(99, 102, 241, 0.05)) 0%, transparent 60%);\n  pointer-events: none;\n}\n\n.power-metric::after {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 3px;\n  height: 100%;\n  background: var(--op-accent, rgba(99, 102, 241, 0.6));\n  opacity: 0;\n  transition: opacity 0.3s ease;\n}\n\n.power-metric:hover {\n  border-color: var(--op-accent-border, rgba(255, 255, 255, 0.08));\n  transform: translateY(-2px);\n  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5), 0 0 20px var(--op-accent-bg, rgba(99, 102, 241, 0.04));\n}\n\n.power-metric:hover::after {\n  opacity: 1;\n}\n\n/* ── SOVEREIGN GRID — Сітка з ефектом глибини ── */\n\n.sovereign-grid {\n  position: relative;\n}\n\n.sovereign-grid::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  pointer-events: none;\n  opacity: 0.015;\n  background-image:\n    linear-gradient(var(--op-accent, rgba(99,102,241,0.3)) 1px, transparent 1px),\n    linear-gradient(90deg, var(--op-accent, rgba(99,102,241,0.3)) 1px, transparent 1px);\n  background-size: 60px 60px;\n  z-index: 0;\n}\n\n/* ── DANGER STRIPE — Тривожна смуга для критичних секцій ── */\n\n.danger-stripe {\n  position: relative;\n  overflow: hidden;\n}\n\n.danger-stripe::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  height: 3px;\n  background: repeating-linear-gradient(\n    90deg,\n    rgba(239, 68, 68, 0.6) 0px,\n    rgba(239, 68, 68, 0.6) 12px,\n    transparent 12px,\n    transparent 20px\n  );\n  animation: danger-march 1s linear infinite;\n}\n\n@keyframes danger-march {\n  0% { background-position: 0 0; }\n  100% { background-position: 20px 0; }\n}\n\n/* ── RADAR SWEEP — Радарний ефект для активних секцій ── */\n\n@keyframes radar-sweep-bg {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n\n.radar-sweep {\n  position: relative;\n  overflow: hidden;\n}\n\n.radar-sweep::after {\n  content: '';\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  width: 200%;\n  height: 200%;\n  transform-origin: center;\n  background: conic-gradient(\n    from 0deg,\n    transparent 0deg,\n    transparent 340deg,\n    var(--op-accent-bg, rgba(99, 102, 241, 0.06)) 350deg,\n    transparent 360deg\n  );\n  animation: radar-sweep-bg 8s linear infinite;\n  pointer-events: none;\n  opacity: 0.4;\n}\n\n/* ── INTEL TICKER — Рядок оперативної інформації ── */\n\n@keyframes intel-scroll {\n  0% { transform: translateX(0); }\n  100% { transform: translateX(-50%); }\n}\n\n.intel-ticker {\n  overflow: hidden;\n  white-space: nowrap;\n  background: rgba(1, 4, 9, 0.9);\n  border-top: 1px solid rgba(255, 255, 255, 0.03);\n  border-bottom: 1px solid rgba(255, 255, 255, 0.03);\n}\n\n.intel-ticker-content {\n  display: inline-block;\n  animation: intel-scroll 60s linear infinite;\n}\n\n/* ── HOLOGRAPHIC SHIMMER — Голографічний відблиск для преміальних карток ── */\n\n@keyframes holo-shine {\n  0% { left: -120%; }\n  30% { left: 120%; }\n  100% { left: 120%; }\n}\n\n.holo-shimmer {\n  position: relative;\n  overflow: hidden;\n}\n\n.holo-shimmer::after {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -120%;\n  width: 60%;\n  height: 100%;\n  background: linear-gradient(\n    105deg,\n    transparent 0%,\n    rgba(255, 255, 255, 0.02) 40%,\n    rgba(255, 255, 255, 0.06) 50%,\n    rgba(255, 255, 255, 0.02) 60%,\n    transparent 100%\n  );\n  transform: skewX(-15deg);\n  animation: holo-shine 6s ease-in-out infinite;\n  pointer-events: none;\n}\n\n/* ── NEXUS PULSE — Пульсуючий ефект для активних елементів ── */\n\n@keyframes nexus-breathe {\n  0%, 100% {\n    box-shadow: 0 0 10px var(--op-accent-bg, rgba(99, 102, 241, 0.05));\n  }\n  50% {\n    box-shadow:\n      0 0 20px var(--op-accent-bg, rgba(99, 102, 241, 0.1)),\n      0 0 40px var(--op-accent-bg, rgba(99, 102, 241, 0.03));\n  }\n}\n\n.nexus-pulse {\n  animation: nexus-breathe 4s ease-in-out infinite;\n}\n\n/* ── DEPTH SHADOW LAYERS — Глибокі тіні для преміального відчуття ── */\n\n.depth-shadow-1 {\n  box-shadow:\n    0 2px 8px rgba(0, 0, 0, 0.3),\n    0 8px 24px rgba(0, 0, 0, 0.2);\n}\n\n.depth-shadow-2 {\n  box-shadow:\n    0 4px 16px rgba(0, 0, 0, 0.4),\n    0 12px 48px rgba(0, 0, 0, 0.3),\n    0 0 0 1px rgba(255, 255, 255, 0.03);\n}\n\n.depth-shadow-3 {\n  box-shadow:\n    0 8px 32px rgba(0, 0, 0, 0.5),\n    0 24px 80px rgba(0, 0, 0, 0.4),\n    0 0 0 1px rgba(255, 255, 255, 0.04),\n    inset 0 1px 0 rgba(255, 255, 255, 0.04);\n}\n\n/* ── SCANLINE FAST — Швидкий скануючий ефект для CyberGrid ── */\n\n@keyframes scanline-fast {\n  0% { transform: translateY(-100%); }\n  100% { transform: translateY(500%); }\n}\n\n.animate-scanline-fast {\n  animation: scanline-fast 4s linear infinite;\n}\n\n/* ── ELITE HEADING ── */\n\n.elite-heading {\n  font-family: var(--font-display);\n  font-weight: 800;\n  letter-spacing: -0.02em;\n  color: #f8fafc;\n  text-transform: uppercase;\n}\n\n/* ── CYBER SCAN GRID ── */\n\n.cyber-scan-grid {\n  background-image: \n    linear-gradient(rgba(244, 63, 94, 0.05) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(244, 63, 94, 0.05) 1px, transparent 1px);\n  background-size: 40px 40px;\n  position: relative;\n}\n\n.cyber-scan-grid::after {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  height: 2px;\n  background: linear-gradient(90deg, transparent, var(--wraith-accent), transparent);\n  animation: scan-line-move var(--scan-speed) linear infinite;\n  opacity: 0.5;\n  box-shadow: 0 0 15px var(--wraith-accent);\n}\n\n@keyframes scan-line-move {\n  0% { top: 0%; opacity: 0; }\n  5% { opacity: 0.5; }\n  95% { opacity: 0.5; }\n  100% { top: 100%; opacity: 0; }\n}\n\n/* ── TACTICAL FOCUS DOTS ── */\n\n.focus-dot {\n  width: 4px;\n  height: 4px;\n  background: var(--wraith-accent);\n  border-radius: 50%;\n  position: absolute;\n  box-shadow: 0 0 8px var(--wraith-accent);\n}\n\n/* ═══════════════════════════════════════════════════\n   THERMAL HOVER — елемент \"нагрівається\" при hover\n   ═══════════════════════════════════════════════════ */\n\n.thermal-hover {\n  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  position: relative;\n}\n\n.thermal-hover::before {\n  content: '';\n  position: absolute;\n  inset: -1px;\n  border-radius: inherit;\n  background: radial-gradient(\n    circle at var(--mouse-x, 50%) var(--mouse-y, 50%),\n    rgba(244, 63, 94, 0.15) 0%,\n    transparent 60%\n  );\n  opacity: 0;\n  transition: opacity 0.4s ease;\n  pointer-events: none;\n  z-index: -1;\n}\n\n.thermal-hover:hover {\n  border-color: rgba(244, 63, 94, 0.4) !important;\n  box-shadow:\n    0 0 20px rgba(244, 63, 94, 0.1),\n    0 0 40px rgba(244, 63, 94, 0.05);\n  transform: translateY(-2px);\n}\n\n.thermal-hover:hover::before {\n  opacity: 1;\n}\n\n/* ═══════════════════════════════════════════════════\n   SLIDE-TO-EXECUTE — свайп для підтвердження дії\n   ═══════════════════════════════════════════════════ */\n\n@keyframes slide-shimmer {\n  0% { background-position: -200% center; }\n  100% { background-position: 200% center; }\n}\n\n.slide-to-execute {\n  position: relative;\n  overflow: hidden;\n  cursor: grab;\n  -webkit-user-select: none;\n     -moz-user-select: none;\n          user-select: none;\n  touch-action: pan-x;\n}\n\n.slide-to-execute::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(\n    90deg,\n    transparent 0%,\n    rgba(244, 63, 94, 0.15) 30%,\n    rgba(244, 63, 94, 0.25) 50%,\n    rgba(244, 63, 94, 0.15) 70%,\n    transparent 100%\n  );\n  background-size: 200% 100%;\n  animation: slide-shimmer 3s linear infinite;\n  opacity: 0;\n  transition: opacity 0.3s ease;\n}\n\n.slide-to-execute:hover::after {\n  opacity: 1;\n}\n\n.slide-to-execute:active {\n  cursor: grabbing;\n}\n\n.slide-thumb {\n  position: absolute;\n  top: 4px;\n  left: 4px;\n  bottom: 4px;\n  width: 48px;\n  background: linear-gradient(135deg, #e11d48, #f43f5e);\n  border-radius: 6px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 2px 12px rgba(225, 29, 72, 0.4);\n  transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;\n}\n\n.slide-thumb.unlocked {\n  left: calc(100% - 52px);\n  background: linear-gradient(135deg, #10b981, #34d399);\n  box-shadow: 0 2px 12px rgba(16, 185, 129, 0.4);\n}\n\n/* ═══════════════════════════════════════════════════\n   KINETIC PARALLAX DEPTH — шари з різною швидкістю\n   ═══════════════════════════════════════════════════ */\n\n.parallax-layer {\n  will-change: transform;\n  transition: transform 0.1s linear;\n}\n\n.parallax-deep { --parallax-depth: 0.2; }\n\n.parallax-mid  { --parallax-depth: 0.5; }\n\n.parallax-shallow { --parallax-depth: 0.8; }\n\n/* ═══════════════════════════════════════════════════\n   DECRYPTION LOADER — замість звичайного spinner\n   ═══════════════════════════════════════════════════ */\n\n@keyframes decrypt-scramble {\n  0%, 100% { content: '█'; }\n  10% { content: '▓'; }\n  20% { content: '▒'; }\n  30% { content: '░'; }\n  40% { content: '◆'; }\n  50% { content: '◇'; }\n  60% { content: '●'; }\n  70% { content: '○'; }\n  80% { content: '◐'; }\n  90% { content: '◑'; }\n}\n\n.decrypt-loader {\n  font-family: 'IBM Plex Mono', monospace;\n  color: #e11d48;\n  font-size: 14px;\n  letter-spacing: 0.15em;\n  display: inline-flex;\n  align-items: center;\n  gap: 4px;\n}\n\n.decrypt-loader::after {\n  content: '█';\n  animation: decrypt-scramble 0.8s steps(10) infinite;\n}\n\n/* ═══════════════════════════════════════════════════\n   BLOOD PULSE — пульсуючий елемент (критичний статус)\n   ═══════════════════════════════════════════════════ */\n\n@keyframes blood-pulse {\n  0%, 100% { box-shadow: 0 0 0 0 rgba(225, 29, 72, 0.4); }\n  50% { box-shadow: 0 0 0 8px rgba(225, 29, 72, 0); }\n}\n\n.blood-pulse {\n  animation: blood-pulse 2s ease-in-out infinite;\n}\n\n/* ═══════════════════════════════════════════════════\n   DATA STREAM — анімований текстовий потік\n   ═══════════════════════════════════════════════════ */\n\n@keyframes data-stream {\n  0% { transform: translateY(0); opacity: 1; }\n  100% { transform: translateY(-20px); opacity: 0; }\n}\n\n.data-stream-char {\n  display: inline-block;\n  animation: data-stream 0.6s ease-out forwards;\n}\n\n*, ::before, ::after{\n  --tw-border-spacing-x: 0;\n  --tw-border-spacing-y: 0;\n  --tw-translate-x: 0;\n  --tw-translate-y: 0;\n  --tw-rotate: 0;\n  --tw-skew-x: 0;\n  --tw-skew-y: 0;\n  --tw-scale-x: 1;\n  --tw-scale-y: 1;\n  --tw-pan-x:  ;\n  --tw-pan-y:  ;\n  --tw-pinch-zoom:  ;\n  --tw-scroll-snap-strictness: proximity;\n  --tw-gradient-from-position:  ;\n  --tw-gradient-via-position:  ;\n  --tw-gradient-to-position:  ;\n  --tw-ordinal:  ;\n  --tw-slashed-zero:  ;\n  --tw-numeric-figure:  ;\n  --tw-numeric-spacing:  ;\n  --tw-numeric-fraction:  ;\n  --tw-ring-inset:  ;\n  --tw-ring-offset-width: 0px;\n  --tw-ring-offset-color: #fff;\n  --tw-ring-color: rgb(59 130 246 / 0.5);\n  --tw-ring-offset-shadow: 0 0 #0000;\n  --tw-ring-shadow: 0 0 #0000;\n  --tw-shadow: 0 0 #0000;\n  --tw-shadow-colored: 0 0 #0000;\n  --tw-blur:  ;\n  --tw-brightness:  ;\n  --tw-contrast:  ;\n  --tw-grayscale:  ;\n  --tw-hue-rotate:  ;\n  --tw-invert:  ;\n  --tw-saturate:  ;\n  --tw-sepia:  ;\n  --tw-drop-shadow:  ;\n  --tw-backdrop-blur:  ;\n  --tw-backdrop-brightness:  ;\n  --tw-backdrop-contrast:  ;\n  --tw-backdrop-grayscale:  ;\n  --tw-backdrop-hue-rotate:  ;\n  --tw-backdrop-invert:  ;\n  --tw-backdrop-opacity:  ;\n  --tw-backdrop-saturate:  ;\n  --tw-backdrop-sepia:  ;\n  --tw-contain-size:  ;\n  --tw-contain-layout:  ;\n  --tw-contain-paint:  ;\n  --tw-contain-style:  ;\n}\n\n::backdrop{\n  --tw-border-spacing-x: 0;\n  --tw-border-spacing-y: 0;\n  --tw-translate-x: 0;\n  --tw-translate-y: 0;\n  --tw-rotate: 0;\n  --tw-skew-x: 0;\n  --tw-skew-y: 0;\n  --tw-scale-x: 1;\n  --tw-scale-y: 1;\n  --tw-pan-x:  ;\n  --tw-pan-y:  ;\n  --tw-pinch-zoom:  ;\n  --tw-scroll-snap-strictness: proximity;\n  --tw-gradient-from-position:  ;\n  --tw-gradient-via-position:  ;\n  --tw-gradient-to-position:  ;\n  --tw-ordinal:  ;\n  --tw-slashed-zero:  ;\n  --tw-numeric-figure:  ;\n  --tw-numeric-spacing:  ;\n  --tw-numeric-fraction:  ;\n  --tw-ring-inset:  ;\n  --tw-ring-offset-width: 0px;\n  --tw-ring-offset-color: #fff;\n  --tw-ring-color: rgb(59 130 246 / 0.5);\n  --tw-ring-offset-shadow: 0 0 #0000;\n  --tw-ring-shadow: 0 0 #0000;\n  --tw-shadow: 0 0 #0000;\n  --tw-shadow-colored: 0 0 #0000;\n  --tw-blur:  ;\n  --tw-brightness:  ;\n  --tw-contrast:  ;\n  --tw-grayscale:  ;\n  --tw-hue-rotate:  ;\n  --tw-invert:  ;\n  --tw-saturate:  ;\n  --tw-sepia:  ;\n  --tw-drop-shadow:  ;\n  --tw-backdrop-blur:  ;\n  --tw-backdrop-brightness:  ;\n  --tw-backdrop-contrast:  ;\n  --tw-backdrop-grayscale:  ;\n  --tw-backdrop-hue-rotate:  ;\n  --tw-backdrop-invert:  ;\n  --tw-backdrop-opacity:  ;\n  --tw-backdrop-saturate:  ;\n  --tw-backdrop-sepia:  ;\n  --tw-contain-size:  ;\n  --tw-contain-layout:  ;\n  --tw-contain-paint:  ;\n  --tw-contain-style:  ;\n}\n\n/* ! tailwindcss v3.4.19 | MIT License | https://tailwindcss.com */\n\n/*\n1. Prevent padding and border from affecting element width. (https://github.com/mozdevs/cssremedy/issues/4)\n2. Allow adding a border to an element by just adding a border-width. (https://github.com/tailwindcss/tailwindcss/pull/116)\n*/\n\n*,\n::before,\n::after {\n  box-sizing: border-box; /* 1 */\n  border-width: 0; /* 2 */\n  border-style: solid; /* 2 */\n  border-color: #e5e7eb; /* 2 */\n}\n\n::before,\n::after {\n  --tw-content: '';\n}\n\n/*\n1. Use a consistent sensible line-height in all browsers.\n2. Prevent adjustments of font size after orientation changes in iOS.\n3. Use a more readable tab size.\n4. Use the user's configured `sans` font-family by default.\n5. Use the user's configured `sans` font-feature-settings by default.\n6. Use the user's configured `sans` font-variation-settings by default.\n7. Disable tap highlights on iOS\n*/\n\nhtml,\n:host {\n  line-height: 1.5; /* 1 */\n  -webkit-text-size-adjust: 100%; /* 2 */\n  -moz-tab-size: 4; /* 3 */\n  -o-tab-size: 4;\n     tab-size: 4; /* 3 */\n  font-family: Plus Jakarta Sans, system-ui, sans-serif; /* 4 */\n  font-feature-settings: normal; /* 5 */\n  font-variation-settings: normal; /* 6 */\n  -webkit-tap-highlight-color: transparent; /* 7 */\n}\n\n/*\n1. Remove the margin in all browsers.\n2. Inherit line-height from `html` so users can set them as a class directly on the `html` element.\n*/\n\nbody {\n  margin: 0; /* 1 */\n  line-height: inherit; /* 2 */\n}\n\n/*\n1. Add the correct height in Firefox.\n2. Correct the inheritance of border color in Firefox. (https://bugzilla.mozilla.org/show_bug.cgi?id=190655)\n3. Ensure horizontal rules are visible by default.\n*/\n\nhr {\n  height: 0; /* 1 */\n  color: inherit; /* 2 */\n  border-top-width: 1px; /* 3 */\n}\n\n/*\nAdd the correct text decoration in Chrome, Edge, and Safari.\n*/\n\nabbr:where([title]) {\n  -webkit-text-decoration: underline dotted;\n          text-decoration: underline dotted;\n}\n\n/*\nRemove the default font size and weight for headings.\n*/\n\nh1,\nh2,\nh3,\nh4,\nh5,\nh6 {\n  font-size: inherit;\n  font-weight: inherit;\n}\n\n/*\nReset links to optimize for opt-in styling instead of opt-out.\n*/\n\na {\n  color: inherit;\n  text-decoration: inherit;\n}\n\n/*\nAdd the correct font weight in Edge and Safari.\n*/\n\nb,\nstrong {\n  font-weight: bolder;\n}\n\n/*\n1. Use the user's configured `mono` font-family by default.\n2. Use the user's configured `mono` font-feature-settings by default.\n3. Use the user's configured `mono` font-variation-settings by default.\n4. Correct the odd `em` font sizing in all browsers.\n*/\n\ncode,\nkbd,\nsamp,\npre {\n  font-family: IBM Plex Mono, JetBrains Mono, ui-monospace, monospace; /* 1 */\n  font-feature-settings: normal; /* 2 */\n  font-variation-settings: normal; /* 3 */\n  font-size: 1em; /* 4 */\n}\n\n/*\nAdd the correct font size in all browsers.\n*/\n\nsmall {\n  font-size: 80%;\n}\n\n/*\nPrevent `sub` and `sup` elements from affecting the line height in all browsers.\n*/\n\nsub,\nsup {\n  font-size: 75%;\n  line-height: 0;\n  position: relative;\n  vertical-align: baseline;\n}\n\nsub {\n  bottom: -0.25em;\n}\n\nsup {\n  top: -0.5em;\n}\n\n/*\n1. Remove text indentation from table contents in Chrome and Safari. (https://bugs.chromium.org/p/chromium/issues/detail?id=999088, https://bugs.webkit.org/show_bug.cgi?id=201297)\n2. Correct table border color inheritance in all Chrome and Safari. (https://bugs.chromium.org/p/chromium/issues/detail?id=935729, https://bugs.webkit.org/show_bug.cgi?id=195016)\n3. Remove gaps between table borders by default.\n*/\n\ntable {\n  text-indent: 0; /* 1 */\n  border-color: inherit; /* 2 */\n  border-collapse: collapse; /* 3 */\n}\n\n/*\n1. Change the font styles in all browsers.\n2. Remove the margin in Firefox and Safari.\n3. Remove default padding in all browsers.\n*/\n\nbutton,\ninput,\noptgroup,\nselect,\ntextarea {\n  font-family: inherit; /* 1 */\n  font-feature-settings: inherit; /* 1 */\n  font-variation-settings: inherit; /* 1 */\n  font-size: 100%; /* 1 */\n  font-weight: inherit; /* 1 */\n  line-height: inherit; /* 1 */\n  letter-spacing: inherit; /* 1 */\n  color: inherit; /* 1 */\n  margin: 0; /* 2 */\n  padding: 0; /* 3 */\n}\n\n/*\nRemove the inheritance of text transform in Edge and Firefox.\n*/\n\nbutton,\nselect {\n  text-transform: none;\n}\n\n/*\n1. Correct the inability to style clickable types in iOS and Safari.\n2. Remove default button styles.\n*/\n\nbutton,\ninput:where([type='button']),\ninput:where([type='reset']),\ninput:where([type='submit']) {\n  -webkit-appearance: button; /* 1 */\n  background-color: transparent; /* 2 */\n  background-image: none; /* 2 */\n}\n\n/*\nUse the modern Firefox focus style for all focusable elements.\n*/\n\n:-moz-focusring {\n  outline: auto;\n}\n\n/*\nRemove the additional `:invalid` styles in Firefox. (https://github.com/mozilla/gecko-dev/blob/2f9eacd9d3d995c937b4251a5557d95d494c9be1/layout/style/res/forms.css#L728-L737)\n*/\n\n:-moz-ui-invalid {\n  box-shadow: none;\n}\n\n/*\nAdd the correct vertical alignment in Chrome and Firefox.\n*/\n\nprogress {\n  vertical-align: baseline;\n}\n\n/*\nCorrect the cursor style of increment and decrement buttons in Safari.\n*/\n\n::-webkit-inner-spin-button,\n::-webkit-outer-spin-button {\n  height: auto;\n}\n\n/*\n1. Correct the odd appearance in Chrome and Safari.\n2. Correct the outline style in Safari.\n*/\n\n[type='search'] {\n  -webkit-appearance: textfield; /* 1 */\n  outline-offset: -2px; /* 2 */\n}\n\n/*\nRemove the inner padding in Chrome and Safari on macOS.\n*/\n\n::-webkit-search-decoration {\n  -webkit-appearance: none;\n}\n\n/*\n1. Correct the inability to style clickable types in iOS and Safari.\n2. Change font properties to `inherit` in Safari.\n*/\n\n::-webkit-file-upload-button {\n  -webkit-appearance: button; /* 1 */\n  font: inherit; /* 2 */\n}\n\n/*\nAdd the correct display in Chrome and Safari.\n*/\n\nsummary {\n  display: list-item;\n}\n\n/*\nRemoves the default spacing and border for appropriate elements.\n*/\n\nblockquote,\ndl,\ndd,\nh1,\nh2,\nh3,\nh4,\nh5,\nh6,\nhr,\nfigure,\np,\npre {\n  margin: 0;\n}\n\nfieldset {\n  margin: 0;\n  padding: 0;\n}\n\nlegend {\n  padding: 0;\n}\n\nol,\nul,\nmenu {\n  list-style: none;\n  margin: 0;\n  padding: 0;\n}\n\n/*\nReset default styling for dialogs.\n*/\n\ndialog {\n  padding: 0;\n}\n\n/*\nPrevent resizing textareas horizontally by default.\n*/\n\ntextarea {\n  resize: vertical;\n}\n\n/*\n1. Reset the default placeholder opacity in Firefox. (https://github.com/tailwindlabs/tailwindcss/issues/3300)\n2. Set the default placeholder color to the user's configured gray 400 color.\n*/\n\ninput::-moz-placeholder, textarea::-moz-placeholder {\n  opacity: 1; /* 1 */\n  color: #9ca3af; /* 2 */\n}\n\ninput::placeholder,\ntextarea::placeholder {\n  opacity: 1; /* 1 */\n  color: #9ca3af; /* 2 */\n}\n\n/*\nSet the default cursor for buttons.\n*/\n\nbutton,\n[role=\"button\"] {\n  cursor: pointer;\n}\n\n/*\nMake sure disabled buttons don't get the pointer cursor.\n*/\n\n:disabled {\n  cursor: default;\n}\n\n/*\n1. Make replaced elements `display: block` by default. (https://github.com/mozdevs/cssremedy/issues/14)\n2. Add `vertical-align: middle` to align replaced elements more sensibly by default. (https://github.com/jensimmons/cssremedy/issues/14#issuecomment-634934210)\n   This can trigger a poorly considered lint error in some tools but is included by design.\n*/\n\nimg,\nsvg,\nvideo,\ncanvas,\naudio,\niframe,\nembed,\nobject {\n  display: block; /* 1 */\n  vertical-align: middle; /* 2 */\n}\n\n/*\nConstrain images and videos to the parent width and preserve their intrinsic aspect ratio. (htt
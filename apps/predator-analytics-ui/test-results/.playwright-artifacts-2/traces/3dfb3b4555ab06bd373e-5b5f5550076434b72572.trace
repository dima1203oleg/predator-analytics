le) var(--tw-backdrop-hue-rotate) var(--tw-backdrop-invert) var(--tw-backdrop-opacity) var(--tw-backdrop-saturate) var(--tw-backdrop-sepia);\n}\n\n.backdrop-filter{\n  backdrop-filter: var(--tw-backdrop-blur) var(--tw-backdrop-brightness) var(--tw-backdrop-contrast) var(--tw-backdrop-grayscale) var(--tw-backdrop-hue-rotate) var(--tw-backdrop-invert) var(--tw-backdrop-opacity) var(--tw-backdrop-saturate) var(--tw-backdrop-sepia);\n}\n\n.transition{\n  transition-property: color, background-color, border-color, text-decoration-color, fill, stroke, opacity, box-shadow, transform, filter, backdrop-filter;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\n\n.transition-\\[max-width\\]{\n  transition-property: max-width;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\n\n.transition-all{\n  transition-property: all;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\n\n.transition-colors{\n  transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\n\n.transition-opacity{\n  transition-property: opacity;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\n\n.transition-shadow{\n  transition-property: box-shadow;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\n\n.transition-transform{\n  transition-property: transform;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\n\n.delay-100{\n  transition-delay: 100ms;\n}\n\n.delay-150{\n  transition-delay: 150ms;\n}\n\n.delay-300{\n  transition-delay: 300ms;\n}\n\n.delay-75{\n  transition-delay: 75ms;\n}\n\n.duration-100{\n  transition-duration: 100ms;\n}\n\n.duration-1000{\n  transition-duration: 1000ms;\n}\n\n.duration-200{\n  transition-duration: 200ms;\n}\n\n.duration-300{\n  transition-duration: 300ms;\n}\n\n.duration-500{\n  transition-duration: 500ms;\n}\n\n.duration-700{\n  transition-duration: 700ms;\n}\n\n.duration-75{\n  transition-duration: 75ms;\n}\n\n.duration-\\[10s\\]{\n  transition-duration: 10s;\n}\n\n.duration-\\[15s\\]{\n  transition-duration: 15s;\n}\n\n.duration-\\[2000ms\\]{\n  transition-duration: 2000ms;\n}\n\n.duration-\\[2s\\]{\n  transition-duration: 2s;\n}\n\n.duration-\\[3000ms\\]{\n  transition-duration: 3000ms;\n}\n\n.duration-\\[3s\\]{\n  transition-duration: 3s;\n}\n\n.duration-\\[4000ms\\]{\n  transition-duration: 4000ms;\n}\n\n.duration-\\[5s\\]{\n  transition-duration: 5s;\n}\n\n.duration-\\[8s\\]{\n  transition-duration: 8s;\n}\n\n.ease-\\[cubic-bezier\\(0\\.16\\2c 1\\2c 0\\.3\\2c 1\\)\\]{\n  transition-timing-function: cubic-bezier(0.16,1,0.3,1);\n}\n\n.ease-in-out{\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.ease-linear{\n  transition-timing-function: linear;\n}\n\n.ease-out{\n  transition-timing-function: cubic-bezier(0, 0, 0.2, 1);\n}\n\n.will-change-transform{\n  will-change: transform;\n}\n\n.touch-manipulation {\n    touch-action: manipulation;\n  }\n\n.overscroll-contain {\n    overscroll-behavior: contain;\n  }\n\n.scrollbar-hide {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n\n.scrollbar-hide::-webkit-scrollbar {\n    display: none;\n  }\n\n.\\[animation-delay\\:-0\\.15s\\]{\n  animation-delay: -0.15s;\n}\n\n.\\[animation-delay\\:-0\\.3s\\]{\n  animation-delay: -0.3s;\n}\n\n.\\[animation-duration\\:3s\\]{\n  animation-duration: 3s;\n}\n\n.\\[mask-image\\:linear-gradient\\(to_bottom\\2c transparent\\2c black\\2c transparent\\)\\]{\n  -webkit-mask-image: linear-gradient(to bottom,transparent,black,transparent);\n          mask-image: linear-gradient(to bottom,transparent,black,transparent);\n}\n\n.\\[mask-image\\:radial-gradient\\(ellipse_80\\%_50\\%_at_50\\%_50\\%\\2c \\#000_70\\%\\2c transparent_100\\%\\)\\]{\n  -webkit-mask-image: radial-gradient(ellipse 80% 50% at 50% 50%,#000 70%,transparent 100%);\n          mask-image: radial-gradient(ellipse 80% 50% at 50% 50%,#000 70%,transparent 100%);\n}\n\n.\\[text-wrap\\:balance\\]{\n  text-wrap: balance;\n}\n\n:root {\n    /* Predator Elite Tokens v63.0-ELITE */\n    --background: 230 25% 2%;\n    --foreground: 210 40% 98%;\n    --primary: 348 100% 60%; /* Elite Rose */\n    --primary-glow: rgba(244, 63, 94, 0.4);\n\n    /* Premium Palette - Deep Black & Blood Red */\n    --elite-black: #0a0a0a;\n    --elite-black-deep: #050505;\n    --elite-white: #ffffff;\n    --elite-white-muted: #f8fafc;\n    --elite-red: #e11d48; /* Blood Red */\n    --elite-red-deep: #9f1239;\n    --elite-red-glow: rgba(225, 29, 72, 0.4);\n\n    --wraith-glass: rgba(8, 12, 22, 0.92);\n    --wraith-border: rgba(244, 63, 94, 0.3);\n    --wraith-accent: #f43f5e; /* Elite Rose */\n    --wraith-accent-deep: #9f1239;\n\n    /* ── AURUM OBSIDIAN TOKENS v2.0 ── */\n    --aurum-gold: #c9a227;\n    --aurum-gold-muted: rgba(201, 162, 39, 0.6);\n    --aurum-glow: rgba(201, 162, 39, 0.25);\n    --titanium: #8a8a8a;\n    --titanium-muted: #5a5a5a;\n    --obsidian: #010101;\n    --obsidian-surface: #0a0a0c;\n    --tactical-teal: #4ecdc4;\n    --tactical-teal-glow: rgba(78, 205, 196, 0.3);\n\n    --aura-gold: hsla(348, 100%, 60%, 0.18);\n    --aura-amber: hsla(340, 100%, 50%, 0.12);\n\n    --glass-bg: rgba(12, 12, 14, 0.85);\n    --glass-border: rgba(255, 255, 255, 0.04);\n    --glass-highlight: rgba(255, 255, 255, 0.03);\n    --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n    --glass-inset: inset 0 1px 0 rgba(255, 255, 255, 0.03);\n\n    --glint-speed: 4s;\n    --scan-speed: 10s;\n    --glint-angle: 135deg;\n    --chromatic-offset: 1.5px;\n    --elite-glint: linear-gradient(var(--glint-angle), transparent 20%, rgba(244, 63, 94, 0.2) 50%, transparent 80%);\n}\n\n.glass-wraith {\n    background: rgba(20, 20, 22, 0.95);\n    border: 1px solid rgba(255, 255, 255, 0.06);\n    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.5);\n    transition: all 0.3s ease;\n    position: relative;\n    overflow: hidden;\n}\n\n.glass-wraith:hover {\n    border-color: rgba(196, 18, 48, 0.3);\n    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.7);\n    transform: translateY(-2px);\n}\n\n.aura-bg {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100vw;\n    height: 100vh;\n    background-color: #0a0a0a;\n    background-image:\n        linear-gradient(rgba(180, 25, 40, 0.1) 1px, transparent 1px),\n        linear-gradient(90deg, rgba(180, 25, 40, 0.1) 1px, transparent 1px);\n    background-size: 48px 48px;\n    z-index: -1;\n}\n\n/* ═══════════════════════════════════════════════════\n   OPERATIONAL MODE SYSTEM (ThemeContext)\n   Динамічна зміна палітри залежно від ситуації\n   ═══════════════════════════════════════════════════ */\n\n/* Плавна transition при зміні операційного режиму */\n\n.op-mode-transition,\n.op-mode-transition * {\n  transition: border-color 0.5s ease, box-shadow 0.5s ease, color 0.3s ease, background-color 0.5s ease !important;\n}\n\n/* Утиліти що використовують операційні змінні */\n\n.op-accent-border { border-color: var(--op-accent-border); }\n\n.op-accent-glow   { box-shadow: var(--op-accent-glow); }\n\n.op-accent-text   { color: var(--op-accent-text); }\n\n.op-accent-bg     { background-color: var(--op-accent-bg); }\n\n/* Пульсуючий індикатор операційного режиму */\n\n@keyframes op-pulse {\n  0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--op-pulse-color); }\n  50%      { opacity: 0.5; box-shadow: 0 0 20px var(--op-pulse-color); }\n}\n\n.op-indicator-pulse {\n  animation: op-pulse 2s ease-in-out infinite;\n  background-color: var(--op-accent);\n}\n\n/* Sidebar з динамічним акцентом */\n\n.op-sidebar-active {\n  background: var(--op-sidebar-active);\n  border: 1px solid var(--op-accent-border);\n  box-shadow: 0 0 20px var(--op-accent-bg);\n}\n\n/* Header glow — тонка лінія */\n\n.op-header-line {\n  background: var(--op-header-glow);\n  height: 1px;\n}\n\n/* Картка з операційним акцентом */\n\n.op-card {\n  border: 1px solid var(--op-accent-border, rgba(255,255,255,0.06));\n  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);\n}\n\n.op-card:hover {\n  box-shadow: var(--op-accent-glow);\n  border-color: var(--op-accent);\n}\n\n/* Scanline з операційним кольором */\n\n@keyframes op-scan-sweep {\n  0%   { transform: translateY(-100%); }\n  100% { transform: translateY(300%); }\n}\n\n.op-scanline::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(\n    to bottom,\n    transparent 0%,\n    var(--op-scanline, rgba(99,102,241,0.03)) 50%,\n    transparent 100%\n  );\n  height: 33%;\n  animation: op-scan-sweep 6s linear infinite;\n  pointer-events: none;\n  z-index: 5;\n}\n\n/* THREAT MODE — заміна агресивно-червоного на насичений розпечений бурштин */\n\n[data-op-mode=\"threat\"] .shell-header-bar {\n  border-bottom-color: rgba(180, 83, 9, 0.4) !important;\n}\n\n[data-op-mode=\"threat\"] .shell-header-bar::after {\n  content: '';\n  position: absolute;\n  bottom: 0;\n  left: 0;\n  right: 0;\n  height: 1px;\n  background: linear-gradient(90deg, transparent, rgba(180, 83, 9, 0.6), transparent);\n}\n\n/* STEALTH MODE — затемнення */\n\n[data-op-mode=\"stealth\"] {\n  --surface-1: rgba(5, 15, 10, 0.85) !important;\n}\n\n/* THEME MODES */\n\n.theme-nato-secure {\n    --background: 222 100% 3%;\n    --primary: 348 100% 60%;\n    --accent: 348 100% 50%;\n    background-color: #00020a;\n}\n\n.theme-matrix-ai {\n    --background: 144 100% 2%;\n    --primary: 142 100% 50%;\n    --accent: 142 100% 40%;\n    background-color: #000500;\n}\n\n:root.high-visibility {\n    --background: 220 40% 8%;\n    --foreground: 210 40% 98%;\n    --muted-foreground: 215 24% 78%;\n    --border: 217 24% 32%;\n    --input: 217 24% 30%;\n    --ring: 196 90% 60%;\n}\n\n.pt-safe {\n    padding-top: var(--sat);\n}\n\n.pb-safe {\n    padding-bottom: var(--sab);\n}\n\n.pl-safe {\n    padding-left: var(--sal);\n}\n\n.pr-safe {\n    padding-right: var(--sar);\n}\n\n.p-safe {\n    padding: var(--sat) var(--sar) var(--sab) var(--sal);\n}\n\n.mt-safe {\n    margin-top: var(--sat);\n}\n\n.mb-safe {\n    margin-bottom: var(--sab);\n}\n\n/* Height utilities that account for dynamic toolbars */\n\n.h-screen-dynamic {\n    height: 100dvh;\n}\n\n.min-h-screen-dynamic {\n    min-height: 100dvh;\n}\n\nbody {\n    color-scheme: dark;\n    background-color: var(--elite-black-deep);\n    color: var(--elite-white);\n    background-image:\n        linear-gradient(rgba(225, 29, 72, 0.08) 1px, transparent 1px),\n        linear-gradient(90deg, rgba(225, 29, 72, 0.08) 1px, transparent 1px);\n    background-size: 48px 48px;\n    background-position: center center;\n    min-height: 100dvh;\n    margin: 0;\n    padding: 0;\n    overflow-x: hidden;\n    -webkit-tap-highlight-color: transparent;\n    -webkit-font-smoothing: antialiased;\n    -webkit-touch-callout: none;\n    -webkit-user-select: none;\n    -moz-user-select: none;\n         user-select: none;\n    text-rendering: optimizeLegibility;\n    background-attachment: fixed;\n    font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);\n    line-height: 1.58;\n    letter-spacing: 0.011em;\n    position: fixed;\n    padding-top: env(safe-area-inset-top);\n    padding-bottom: env(safe-area-inset-bottom);\n    padding-left: env(safe-area-inset-left);\n    padding-right: env(safe-area-inset-right);\n    overflow-y: auto;\n    -webkit-overflow-scrolling: touch;\n    width: 100%;\n    height: 100%;\n    top: 0;\n    left: 0;\n}\n\n#root {\n    min-height: 100dvh;\n    width: 100%;\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    overflow: visible !important;\n}\n\n/* Режим високої видимості */\n\n.high-visibility body {\n    background-color: #030712; /* Rich dark gray-blue for maximum contrast */\n    color: #f8fafc;\n    background-image: none !important; /* Disable grid noise pattern */\n}\n\n/* Вимикаємо розмиття, шуми та сканування для кристальної чіткості */\n\n.high-visibility .scan-lines::after,\n.high-visibility .noise-overlay::after,\n.high-visibility .vignette::before,\n.high-visibility .vignette::after,\n.high-visibility .cyber-scanline,\n.high-visibility .animate-scanline,\n.high-visibility .animate-scanline-fast,\n.high-visibility .bg-cyber-noise,\n.high-visibility .bg-noise {\n    display: none !important;\n    animation: none !important;\n    background-image: none !important;\n}\n\n/* Збільшуємо контрастність токенів */\n\n.high-visibility {\n    --elite-black: #000000 !important;\n    --elite-black-deep: #000000 !important;\n    --bg-canvas: #030712 !important;\n    --bg-surface: #0f172a !important;\n    --bg-elevated: #1e293b !important;\n    --fg-primary: #ffffff !important;\n    --fg-secondary: #f1f5f9 !important;\n    --fg-muted: #94a3b8 !important;\n    --border-subtle: rgba(255, 255, 255, 0.16) !important;\n    --border-default: rgba(255, 255, 255, 0.28) !important;\n    --border-strong: rgba(255, 255, 255, 0.45) !important;\n    --glass-bg: rgba(15, 23, 42, 0.98) !important;\n    --glass-border: rgba(255, 255, 255, 0.3) !important;\n}\n\n.high-visibility .glass-ultra {\n    background: rgba(15, 23, 42, 0.95);\n    border-color: rgba(255, 255, 255, 0.25);\n    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.7);\n}\n\n.high-visibility :where(input, textarea, select) {\n    background-color: rgba(15, 23, 42, 0.95);\n    color: #ffffff;\n    border-color: rgba(255, 255, 255, 0.35);\n}\n\n.high-visibility :where(input, textarea, select):focus {\n    border-color: #38bdf8;\n    box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.35);\n}\n\n.high-visibility ::-moz-placeholder {\n    color: #94a3b8;\n    opacity: 1;\n}\n\n.high-visibility ::placeholder {\n    color: #94a3b8;\n    opacity: 1;\n}\n\n.high-visibility .text-slate-400 {\n    color: #f1f5f9 !important;\n}\n\n.high-visibility .text-slate-500 {\n    color: #cbd5e1 !important;\n}\n\n.high-visibility .text-slate-600 {\n    color: #94a3b8 !important;\n}\n\n.high-visibility .border-white\\/10 {\n    border-color: rgba(255, 255, 255, 0.25) !important;\n}\n\n.high-visibility .border-slate-800\\/50,\n.high-visibility .border-slate-800\\/60,\n.high-visibility .border-slate-800\\/80 {\n    border-color: rgba(255, 255, 255, 0.25) !important;\n}\n\n/* Покращена видимість фокусу */\n\n:focus-visible {\n    outline: 2px solid hsl(var(--ring));\n    outline-offset: 2px;\n}\n\nbutton:focus-visible,\na:focus-visible,\ninput:focus-visible,\nselect:focus-visible,\ntextarea:focus-visible,\n[tabindex]:focus-visible {\n    box-shadow:\n        0 0 0 2px hsl(var(--ring)),\n        0 0 0 6px rgba(2, 6, 23, 0.8);\n}\n\n::-moz-selection {\n    background: rgba(212, 175, 55, 0.35);\n    color: #ffffff;\n}\n\n::selection {\n    background: rgba(212, 175, 55, 0.35);\n    color: #ffffff;\n}\n\n/* ============================================================================\n   SCROLL OPTIMIZATION - Production Ready\n   ============================================================================ */\n\n/* Smooth scrolling для всіх scroll контейнерів */\n\n.scroll-smooth {\n    scroll-behavior: smooth;\n}\n\n/* iOS-specific fixes */\n\n@supports (-webkit-touch-callout: none) {\n    * {\n        -webkit-tap-highlight-color: transparent;\n        -webkit-touch-callout: none;\n    }\n}\n\n/* Покращений scrollbar для всіх браузерів */\n\n/* Premium Noise Texture */\n\n.bg-noise {\n    background-image: var(--noise-texture);\n}\n\n/* Tactical Glass Effects */\n\n.glass-ultra {\n    background: rgba(2, 6, 23, 0.65);\n    backdrop-filter: blur(12px) saturate(180%);\n    -webkit-backdrop-filter: blur(12px) saturate(180%);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: \n        0 8px 32px 0 rgba(0, 0, 0, 0.8),\n        inset 0 0 0 1px rgba(255, 255, 255, 0.05);\n}\n\n.font-display {\n    font-family: var(--font-display, 'Syne', sans-serif);\n    letter-spacing: -0.03em;\n    font-weight: 700;\n}\n\n.surface-panel {\n    background:\n        linear-gradient(180deg, rgba(12, 20, 35, 0.92), rgba(6, 12, 24, 0.86));\n    border: 1px solid var(--shell-border);\n    box-shadow:\n        0 18px 48px rgba(2, 6, 23, 0.38),\n        inset 0 1px 0 rgba(255, 255, 255, 0.04);\n    backdrop-filter: blur(18px);\n    -webkit-backdrop-filter: blur(18px);\n}\n\n.surface-panel-strong {\n    background:\n        linear-gradient(180deg, rgba(10, 18, 32, 0.98), rgba(4, 9, 18, 0.94));\n    border: 1px solid var(--shell-border-strong);\n    box-shadow:\n        0 28px 72px rgba(2, 6, 23, 0.48),\n        inset 0 1px 0 rgba(255, 255, 255, 0.05);\n    backdrop-filter: blur(22px);\n    -webkit-backdrop-filter: blur(22px);\n}\n\n.surface-panel-soft {\n    background: var(--shell-panel-soft);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    backdrop-filter: blur(14px);\n    -webkit-backdrop-filter: blur(14px);\n}\n\n.surface-divider {\n    border-color: rgba(148, 163, 184, 0.12);\n}\n\n.tactical-label {\n    font-size: 0.7rem;\n    font-weight: 700;\n    letter-spacing: 0.24em;\n    text-transform: uppercase;\n    color: #8fa0b8;\n}\n\n.status-pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 0.5rem;\n    border-radius: 9999px;\n    border: 1px solid rgba(148, 163, 184, 0.18);\n    background: rgba(255, 255, 255, 0.04);\n    padding: 0.55rem 0.85rem;\n}\n\n.glass-tactical {\n    background: rgba(0, 12, 31, 0.8);\n    border: 1px solid rgba(0, 243, 255, 0.2);\n    box-shadow: 0 0 20px rgba(0, 243, 255, 0.1);\n}\n\n/* Background Effects */\n\n.bg-matrix {\n    position: relative;\n    overflow: hidden;\n}\n\n.bg-matrix::before {\n    content: \"\";\n    position: absolute;\n    top: 0; left: 0; width: 100%; height: 100%;\n    background: linear-gradient(rgba(0, 255, 65, 0.05) 50%, transparent 50%);\n    background-size: 100% 4px;\n    opacity: 0.1;\n    pointer-events: none;\n    z-index: 1;\n}\n\n.bg-agency-grid {\n    background-image: radial-gradient(circle at center, transparent 0%, #000c1f 100%);\n    background-size: cover;\n}\n\n/* Tactical Scanline CSS-only */\n\n.scanline-tactical {\n    width: 100%;\n    height: 100px;\n    z-index: 100;\n    background: linear-gradient(\n        0deg,\n        rgba(0, 0, 0, 0) 0%,\n        rgba(244, 63, 94, 0.1) 50%,\n        rgba(0, 0, 0, 0) 100%\n    );\n    opacity: 0.1;\n    position: absolute;\n    bottom: 100%;\n    animation: scanline-move 10s linear infinite;\n    pointer-events: none;\n}\n\n@keyframes scanline-move {\n    0% { bottom: 110%; }\n    100% { bottom: -10%; }\n}\n\n/* Iridescent Text Effect */\n\n.text-iridescent {\n    background: linear-gradient(45deg,\n            #60a5fa 0%,\n            #a855f7 25%,\n            #ec4899 50%,\n            #a855f7 75%,\n            #60a5fa 100%);\n    background-size: 200% auto;\n    -webkit-background-clip: text;\n    background-clip: text;\n    -webkit-text-fill-color: transparent;\n    animation: shine 3s linear infinite;\n}\n\n@keyframes shine {\n    to {\n        background-position: 200% center;\n    }\n}\n\n/* Chromatic Aberration Simulation */\n\n.hover-chromatic:hover {\n    text-shadow:\n        2px 0 #ff000088,\n        -2px 0 #00ffff88;\n}\n\n/* 3D Panel depth */\n\n.panel-3d {\n    transform: perspective(1000px) rotateX(0deg);\n    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);\n}\n\n.panel-3d:hover {\n    transform: perspective(1000px) rotateX(1deg) translateY(-2px);\n}\n\n/* Neural pulse effect */\n\n@keyframes neural-pulse {\n\n    0%,\n    100% {\n        filter: drop-shadow(0 0 5px var(--glow-color));\n        opacity: 0.8;\n    }\n\n    50% {\n        filter: drop-shadow(0 0 20px var(--glow-color));\n        opacity: 1;\n    }\n}\n\n.neural-breathing {\n    animation: neural-pulse 4s ease-in-out infinite;\n}\n\n/* Neutralization/Redaction styles */\n\n.redacted-placeholder {\n    background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);\n    background-size: 200% 100%;\n    animation: shimmer 2s infinite;\n    color: transparent;\n    -webkit-user-select: none;\n    -moz-user-select: none;\n         user-select: none;\n    cursor: help;\n    border-radius: 4px;\n}\n\n.forbidden-ghost {\n    background: repeating-linear-gradient(45deg,\n            rgba(239, 68, 68, 0.05),\n            rgba(239, 68, 68, 0.05) 10px,\n            rgba(239, 68, 68, 0.1) 10px,\n            rgba(239, 68, 68, 0.1) 20px);\n    border: 1px dashed var(--color-forbidden);\n    opacity: 0.6;\n}\n\n/* Очікування завантаження React... */\n\n#root:empty {\n    background: #000000;\n}\n\n/* Контраст для таблиць та графіків */\n\ntable {\n    color: #e2e8f0;\n}\n\nthead th {\n    color: #f1f5f9;\n    background: rgba(15, 23, 42, 0.65);\n    border-bottom: 1px solid rgba(148, 163, 184, 0.25);\n}\n\ntbody td {\n    border-bottom: 1px solid rgba(148, 163, 184, 0.15);\n}\n\ntbody tr:hover {\n    background: rgba(148, 163, 184, 0.08);\n}\n\n.recharts-text,\n.recharts-cartesian-axis-tick text,\n.recharts-legend-item-text {\n    fill: #f1f5f9 !important;\n}\n\n.recharts-default-tooltip {\n    background: rgba(2, 6, 23, 0.95) !important;\n    border: 1px solid rgba(148, 163, 184, 0.3) !important;\n    color: #e2e8f0 !important;\n    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.45);\n}\n\n.recharts-cartesian-axis line,\n.recharts-cartesian-axis-tick-line {\n    stroke: #64748b;\n}\n\n.recharts-cartesian-grid line {\n    stroke: #1f2937;\n}\n\n.recharts-tooltip-label,\n.recharts-tooltip-item {\n    color: #e2e8f0 !important;\n}\n\n.recharts-layer text {\n    paint-order: stroke;\n    stroke: #0f172a;\n    stroke-width: 2px;\n    stroke-linejoin: round;\n}\n\n.high-visibility .recharts-cartesian-axis line,\n.high-visibility .recharts-cartesian-axis-tick-line {\n    stroke: #cbd5f5;\n}\n\n.high-visibility .recharts-cartesian-grid line {\n    stroke: #334155;\n}\n\n.high-visibility .recharts-text,\n.high-visibility .recharts-cartesian-axis-tick text,\n.high-visibility .recharts-legend-item-text {\n    fill: #f8fafc !important;\n}\n\n/* Полотно графа (Cytoscape) */\n\n.graph-canvas {\n    background-image:\n        radial-gradient(circle at 20% 10%, rgba(56, 189, 248, 0.08), transparent 45%),\n        radial-gradient(circle at 80% 20%, rgba(94, 234, 212, 0.05), transparent 40%),\n        linear-gradient(180deg, rgba(2, 6, 23, 0.9), rgba(2, 6, 23, 1));\n}\n\n.high-visibility .graph-canvas {\n    background-image:\n        radial-gradient(circle at 20% 10%, rgba(56, 189, 248, 0.14), transparent 45%),\n        radial-gradient(circle at 80% 20%, rgba(94, 234, 212, 0.1), transparent 40%),\n        linear-gradient(180deg, rgba(2, 6, 23, 0.95), rgba(2, 6, 23, 1));\n}\n\n/* Cybercore Simulator Utilities */\n\n.perspective-1000 {\n    perspective: 1000px;\n}\n\n.bg-cyber-noise {\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n    background-repeat: repeat;\n    opacity: 0.1;\n}\n\n.custom-scrollbar::-webkit-scrollbar {\n    width: 3px;\n}\n\n.custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n}\n\n.custom-scrollbar::-webkit-scrollbar-thumb {\n    background: rgba(16, 185, 129, 0.2);\n    border-radius: 10px;\n}\n\n.custom-scrollbar::-webkit-scrollbar-thumb:hover {\n    background: rgba(16, 185, 129, 0.4);\n}\n\n.bg-cyber-grid {\n    background-size: 40px 40px;\n    background-image: linear-gradient(to right, rgba(30, 41, 59, 0.3) 1px, transparent 1px),\n        linear-gradient(to bottom, rgba(30, 41, 59, 0.3) 1px, transparent 1px);\n    -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);\n    mask-image: linear-gradient(to bottom, black 50%, transparent 100%);\n}\n\n/* Cybernetic Utility Classes */\n\n.cyber-blur {\n    filter: blur(1px);\n}\n\n.cyber-blur-sm {\n    filter: blur(0.5px);\n}\n\n.cyber-scanline {\n    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%);\n    background-size: 100% 4px;\n    pointer-events: none;\n}\n\n@keyframes scanline-move {\n    0% { transform: translateY(-100%); }\n    100% { transform: translateY(100%); }\n}\n\n.animate-scanline {\n    animation: scanline-move 8s linear infinite;\n}\n\n.animate-scanline-fast {\n    animation: scanline-move 2s linear infinite;\n}\n\n@keyframes raptor-pulse {\n    0%, 100% { \n        filter: drop-shadow(0 0 15px rgba(6, 182, 212, 0.3)) brightness(1); \n        transform: scale(1); \n    }\n    50% { \n        filter: drop-shadow(0 0 35px rgba(6, 182, 212, 0.5)) brightness(1.2); \n        transform: scale(1.02); \n    }\n}\n\n.animate-raptor-pulse {\n    animation: raptor-pulse 4s ease-in-out infinite;\n}\n\n/* Fix for DNA Bars and dynamic widths */\n\n.dynamic-bar-transition {\n    transition: width 1.5s cubic-bezier(0.2, 0.8, 0.2, 1);\n}\n\n.dynamic-width-bar {\n    width: var(--w, 0%);\n}\n\n/* Data Capsule Styles */\n\n.data-capsule {\n    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8) 0%, rgba(2, 6, 23, 0.9) 100%);\n    border: 1px solid rgba(255, 255, 255, 0.05);\n    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5), inset 0 1px 1px rgba(255, 255, 255, 0.05);\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.data-capsule:hover {\n    border-color: rgba(6, 182, 212, 0.3);\n    box-shadow: 0 8px 32px rgba(6, 182, 212, 0.1), inset 0 1px 1px rgba(255, 255, 255, 0.1);\n}\n\n.holographic-card {\n    background: linear-gradient(110deg, rgba(255, 255, 255, 0.01) 0%, rgba(255, 255, 255, 0.03) 50%, rgba(255, 255, 255, 0.01) 100%);\n    backdrop-filter: blur(16px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    position: relative;\n    overflow: hidden;\n}\n\n.holographic-card::after {\n    content: '';\n    position: absolute;\n    top: -50%;\n    left: -50%;\n    width: 200%;\n    height: 200%;\n    background: linear-gradient(45deg, transparent 45%, rgba(6, 182, 212, 0.05) 50%, transparent 55%);\n    animation: holographic-sweep 10s linear infinite;\n    pointer-events: none;\n}\n\n@keyframes holographic-sweep {\n    0% {\n        transform: translate(-30%, -30%) rotate(0deg);\n    }\n\n    100% {\n        transform: translate(30%, 30%) rotate(360deg);\n    }\n}\n\n.glow-pulse {\n    animation: glow-pulse 3s ease-in-out infinite;\n}\n\n@keyframes glow-pulse {\n\n    0%,\n    100% {\n        filter: drop-shadow(0 0 2px var(--glow-color, #3b82f6));\n        opacity: 0.8;\n    }\n\n    50% {\n        filter: drop-shadow(0 0 8px var(--glow-color, #3b82f6));\n        opacity: 1;\n    }\n}\n\n.holographic-scanline {\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, rgba(6, 182, 212, 0.4), transparent);\n    box-shadow: 0 0 8px rgba(6, 182, 212, 0.8);\n    animation: scanline 4s linear infinite;\n    pointer-events: none;\n    z-index: 50;\n}\n\n@keyframes scanline {\n    0% {\n        top: 0;\n        opacity: 0;\n    }\n\n    5% {\n        opacity: 1;\n    }\n\n    95% {\n        opacity: 1;\n    }\n\n    100% {\n        top: 100%;\n        opacity: 0;\n    }\n}\n\n.neural-scanline {\n    background: linear-gradient(90deg, transparent, var(--pulse-color, #06b6d4), transparent);\n}\n\n.neural-pulse-ring {\n    border-color: var(--pulse-color);\n    box-shadow: 0 0 50px var(--pulse-shadow), inset 0 0 50px var(--pulse-shadow);\n}\n\n.relative-pulse {\n    position: relative;\n}\n\n/* Elite Redacted Effect */\n\n.redacted-elite {\n    background: #000;\n    color: transparent;\n    position: relative;\n    cursor: not-allowed;\n}\n\n.redacted-elite::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(90deg, transparent, rgba(244, 63, 94, 0.2), transparent);\n    background-size: 200% 100%;\n    animation: shimmer 1.5s infinite;\n}\n\n/* Cyber Glitch Effect */\n\n.text-glitch {\n    position: relative;\n    display: inline-block;\n}\n\n.text-glitch::before,\n.text-glitch::after {\n    content: attr(data-text);\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: inherit;\n}\n\n.text-glitch::before {\n    left: 2px;\n    text-shadow: -2px 0 #ff00c1;\n    clip: rect(44px, 450px, 56px, 0);\n    animation: glitch-anim 5s infinite linear alternate-reverse;\n}\n\n.text-glitch::after {\n    left: -2px;\n    text-shadow: -2px 0 #00fff9, 2px 2px #ff00c1;\n    animation: glitch-anim2 1s infinite linear alternate-reverse;\n}\n\n@keyframes glitch-anim {\n  0% { clip: rect(31px, 9999px, 94px, 0); }\n  20% { clip: rect(62px, 9999px, 42px, 0); }\n  40% { clip: rect(10px, 9999px, 86px, 0); }\n  60% { clip: rect(57px, 9999px, 92px, 0); }\n  80% { clip: rect(83px, 9999px, 14px, 0); }\n  100% { clip: rect(25px, 9999px, 5px, 0); }\n}\n\n@keyframes glitch-anim2 {\n  0% { clip: rect(65px, 9999px, 100px, 0); }\n  20% { clip: rect(30px, 9999px, 54px, 0); }\n  40% { clip: rect(15px, 9999px, 92px, 0); }\n  60% { clip: rect(82px, 9999px, 2px, 0); }\n  80% { clip: rect(43px, 9999px, 73px, 0); }\n  100% { clip: rect(10px, 9999px, 35px, 0); }\n}\n\n/* Wraith Shimmer */\n\n@keyframes wraith-shimmer {\n    0% { transform: translateX(-100%) skewX(-15deg); }\n    100% { transform: translateX(200%) skewX(-15deg); }\n}\n\n.shimmer-wraith {\n    position: relative;\n    overflow: hidden;\n}\n\n.shimmer-wraith::after {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 30%;\n    height: 100%;\n    background: linear-gradient(\n        to right,\n        transparent,\n        rgba(244, 63, 94, 0.1),\n        transparent\n    );\n    animation: wraith-shimmer 3s infinite;\n}\n\n.tilt-card-surface {\n    transform-style: preserve-3d;\n    transform: perspective(1000px) rotateX(var(--rx, 0deg)) rotateY(var(--ry, 0deg)) scale(var(--s, 1));\n}\n\n.tilt-glare-layer {\n    background: radial-gradient(circle at var(--gx, 50%) var(--gy, 50%), var(--gc, #fff), transparent 80%);\n}\n\n/* ============================================================================\n   FACTORY / ЗАВОД — Premium Visual Enhancements\n   ============================================================================ */\n\n/* Factory orange glow pulse */\n\n@keyframes factory-glow {\n\n    0%,\n    100% {\n        box-shadow: 0 0 20px rgba(249, 115, 22, 0.2), 0 0 60px rgba(249, 115, 22, 0.1);\n    }\n\n    50% {\n        box-shadow: 0 0 40px rgba(249, 115, 22, 0.4), 0 0 80px rgba(249, 115, 22, 0.15);\n    }\n}\n\n.factory-pulse {\n    animation: factory-glow 3s ease-in-out infinite;\n}\n\n/* OODA pipeline connector pulse */\n\n@keyframes pipeline-flow {\n    0% {\n        background-position: 0% 50%;\n    }\n\n    50% {\n        background-position: 100% 50%;\n    }\n\n    100% {\n        background-position: 0% 50%;\n    }\n}\n\n.pipeline-flow {\n    background: linear-gradient(90deg, #f97316, #f59e0b, #06b6d4, #f97316);\n    background-size: 300% 300%;\n    animation: pipeline-flow 3s ease infinite;\n}\n\n/* Enhanced sidebar item hover */\n\n.sidebar-item-glow:hover {\n    box-shadow: inset 0 0 20px rgba(99, 102, 241, 0.05);\n}\n\n/* Neon border for active states */\n\n.neon-border-orange {\n    border-color: rgba(249, 115, 22, 0.6);\n    box-shadow: 0 0 15px rgba(249, 115, 22, 0.2), inset 0 0 15px rgba(249, 115, 22, 0.05);\n}\n\n.neon-border-cyan {\n    border-color: rgba(6, 182, 212, 0.6);\n    box-shadow: 0 0 15px rgba(6, 182, 212, 0.2), inset 0 0 15px rgba(6, 182, 212, 0.05);\n}\n\n.neon-border-violet {\n    border-color: rgba(139, 92, 246, 0.6);\n    box-shadow: 0 0 15px rgba(139, 92, 246, 0.2), inset 0 0 15px rgba(139, 92, 246, 0.05);\n}\n\n/* Єдина типографіка: sans з токенів, моноширинний для даних */\n\n.font-mono,\ncode,\npre,\nkbd {\n    font-family: var(--font-mono, 'IBM Plex Mono', monospace);\n}\n\n/* Premium card glow on hover */\n\n.premium-card {\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.premium-card:hover {\n    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.06);\n    transform: translateY(-2px);\n}\n\n/* Sidebar active item enhanced glow */\n\n.sidebar-active {\n    background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(6, 182, 212, 0.08) 100%);\n    border: 1px solid rgba(99, 102, 241, 0.25);\n    box-shadow: 0 0 20px rgba(99, 102, 241, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.05);\n}\n\n/* Improved global scrollbar */\n\n* {\n    scrollbar-width: thin;\n    scrollbar-color: rgba(99, 102, 241, 0.2) transparent;\n}\n\n*::-webkit-scrollbar {\n    width: 4px;\n    height: 4px;\n}\n\n*::-webkit-scrollbar-track {\n    background: transparent;\n}\n\n*::-webkit-scrollbar-thumb {\n    background: rgba(99, 102, 241, 0.25);\n    border-radius: 99px;\n}\n\n*::-webkit-scrollbar-thumb:hover {\n    background: rgba(99, 102, 241, 0.45);\n}\n\n.high-visibility * {\n    scrollbar-color: rgba(148, 163, 184, 0.7) transparent;\n}\n\n.high-visibility *::-webkit-scrollbar-thumb {\n    background: rgba(148, 163, 184, 0.55);\n}\n\n.high-visibility *::-webkit-scrollbar-thumb:hover {\n    background: rgba(148, 163, 184, 0.8);\n}\n\n/* AZR status badge pulse */\n\n@keyframes azr-pulse {\n\n    0%,\n    100% {\n        opacity: 1;\n        filter: drop-shadow(0 0 4px rgba(249, 115, 22, 0.6));\n    }\n\n    50% {\n        opacity: 0.7;\n        filter: drop-shadow(0 0 12px rgba(249, 115, 22, 0.9));\n    }\n}\n\n.azr-active {\n    animation: azr-pulse 2s ease-in-out infinite;\n}\n\n/* Gradient headings */\n\n.h-gradient-orange {\n    background: linear-gradient(135deg, #ffffff 0%, #fed7aa 50%, #fb923c 100%);\n    -webkit-background-clip: text;\n    background-clip: text;\n    -webkit-text-fill-color: transparent;\n}\n\n.h-gradient-cyan {\n    background: linear-gradient(135deg, #ffffff 0%, #a5f3fc 50%, #06b6d4 100%);\n    -webkit-background-clip: text;\n    background-clip: text;\n    -webkit-text-fill-color: transparent;\n}\n\n/* ============================================================================\n   PREDATOR v58.2-WRAITH — ПОСИЛЕНА ВІЗУАЛЬНА ЯКІСТЬ\n   Контраст, читабельність, динамічні ефекти, мікро-анімації\n   ============================================================================ */\n\n/* ── PREMIUM GLASSMORPHISM ── */\n\n.glass-premium {\n    background: rgba(5, 5, 5, 0.85);\n    backdrop-filter: blur(20px) saturate(180%);\n    -webkit-backdrop-filter: blur(20px) saturate(180%);\n    border: 1px solid rgba(225, 29, 72, 0.15);\n    box-shadow:\n        0 8px 32px rgba(0, 0, 0, 0.6),\n        inset 0 0 0 1px rgba(255, 255, 255, 0.03),\n        0 0 0 1px rgba(225, 29, 72, 0.05);\n    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);\n}\n\n.glass-premium:hover {\n    border-color: rgba(225, 29, 72, 0.3);\n    box-shadow:\n        0 16px 48px rgba(0, 0, 0, 0.7),\n        inset 0 0 0 1px rgba(255, 255, 255, 0.05),\n        0 0 20px rgba(225, 29, 72, 0.15);\n}\n\n/* ── TECHNOLOGICAL GRID WITH RADAR EFFECT ── */\n\n.tech-grid-bg {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background-color: var(--elite-black-deep);\n    background-image:\n        linear-gradient(rgba(225, 29, 72, 0.05) 1px, transparent 1px),\n        linear-gradient(90deg, rgba(225, 29, 72, 0.05) 1px, transparent 1px);\n    background-size: 40px 40px;\n    pointer-events: none;\n    z-index: -1;\n}\n\n.tech-grid-radar {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    pointer-events: none;\n    z-index: -1;\n    background: radial-gradient(\n        circle at var(--mouse-x, 50%) var(--mouse-y, 50%),\n        rgba(225, 29, 72, 0.08) 0%,\n        transparent 30%\n    );\n}\n\n/* ── PARALLAX DEPTH EFFECT ── */\n\n.parallax-container {\n    perspective: 1000px;\n    transform-style: preserve-3d;\n}\n\n.parallax-layer {\n    transform-style: preserve-3d;\n    transition: transform 0.1s ease-out;\n}\n\n/* ── TACTICAL FOCUS (SNIPER ACCENT) ── */\n\n.tactical-focus-active .tactical-blur {\n    opacity: 0.3;\n    filter: blur(2px);\n    transition: all 0.3s ease;\n}\n\n.tactical-focus-target {\n    opacity: 1;\n    filter: blur(0);\n    box-shadow: 0 0 30px rgba(225, 29, 72, 0.5), 0 0 60px rgba(225, 29, 72, 0.3);\n    border-color: rgba(225, 29, 72, 0.8);\n    transition: all 0.3s ease;\n}\n\n/* ── DECRYPTION EFFECT (REPLACEMENT FOR LOADER) ── */\n\n@keyframes decrypt {\n    0% { opacity: 0; }\n    50% { opacity: 1; }\n    100% { opacity: 0; }\n}\n\n.decrypt-text {\n    position: relative;\n}\n\n.decrypt-text::before {\n    content: attr(data-decrypt);\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: var(--elite-black-deep);\n    color: var(--elite-red);\n    font-family: 'Courier New', monospace;\n    animation: decrypt 0.1s infinite;\n    pointer-events: none;\n}\n\n/* ── THERMAL HOVER EFFECT ── */\n\n.thermal-hover {\n    transition: all 0.3s ease;\n}\n\n.thermal-hover:hover {\n    background: rgba(225, 29, 72, 0.1);\n    box-shadow: 0 0 20px rgba(225, 29, 72, 0.2);\n}\n\n.thermal-hover::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: radial-gradient(\n        circle at var(--mouse-x, 50%) var(--mouse-y, 50%),\n        rgba(225, 29, 72, 0.15),\n        transparent 50%\n    );\n    opacity: 0;\n    transition: opacity 0.3s ease;\n    pointer-events: none;\n}\n\n.thermal-hover:hover::after {\n    opacity: 1;\n}\n\n/* ── ГЛОБАЛЬНІ HOVER MICRO-INTERACTIONS ── */\n\nbutton,\na,\n[role=\"button\"],\n.clickable {\n    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\nbutton:hover:not(:disabled),\n[role=\"button\"]:hover {\n    transform: translateY(-1px);\n}\n\nbutton:active:not(:disabled),\n[role=\"button\"]:active {\n    transform: translateY(0) scale(0.98);\n}\n\n/* ── ПОСИЛЕНА ТИПОГРАФІКА ── */\n\nh1, h2, h3, h4, h5, h6 {\n    color: #f8fafc;\n    font-weight: 700;\n    letter-spacing: -0.01em;\n    text-rendering: geometricPrecision;\n}\n\nh1 { letter-spacing: -0.025em; }\n\nh2 { letter-spacing: -0.02em; }\n\n/* Краща читабельність параграфів */\n\np {\n    color: #cbd5e1;\n    line-height: 1.7;\n}\n\n/* Посилений контраст для label та caption */\n\nlabel, .label-text {\n    color: #94a3b8;\n    font-weight: 600;\n    letter-spacing: 0.03em;\n}\n\n.text-muted, .text-secondary {\n    color: #94a3b8 !important;\n}\n\n/* ── ІНТЕРАКТИВНІ INPUT-ПОЛЯ ── */\n\ninput, textarea, select {\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\ninput:not([type=\"checkbox\"]):not([type=\"radio\"]):hover,\ntextarea:hover,\nselect:hover {\n    border-color: rgba(99, 102, 241, 0.35) !important;\n}\n\ninput:not([type=\"checkbox\"]):not([type=\"radio\"]):focus,\ntextarea:focus,\nselect:focus {\n    border-color: rgba(99, 102, 241, 0.6) !important;\n    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15), 0 0 20px rgba(99, 102, 241, 0.08) !important;\n}\n\n/* ── ПОСИЛЕНІ GLASS ПАНЕЛІ ── */\n\n.glass-ultra {\n    background: rgba(2, 6, 23, 0.72);\n    backdrop-filter: blur(16px) saturate(200%);\n    -webkit-backdrop-filter: blur(16px) saturate(200%);\n    border: 1px solid rgba(255, 255, 255, 0.10);\n    box-shadow:\n        0 10px 40px 0 rgba(0, 0, 0, 0.7),\n        inset 0 0 0 1px rgba(255, 255, 255, 0.06),\n        inset 0 1px 0 rgba(255, 255, 255, 0.08);\n    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);\n}\n\n.glass-ultra:hover {\n    border-color: rgba(255, 255, 255, 0.15);\n    box-shadow:\n        0 16px 56px 0 rgba(0, 0, 0, 0.8),\n        inset 0 0 0 1px rgba(255, 255, 255, 0.08),\n        inset 0 1px 0 rgba(255, 255, 255, 0.12);\n}\n\n/* ── PREMIUM TABLE STYLING ── */\n\ntable {\n    color: #e2e8f0;\n    border-collapse: separate;\n    border-spacing: 0;\n}\n\nthead th {\n    color: #f1f5f9;\n    background: rgba(15, 23, 42, 0.7);\n    border-bottom: 2px solid rgba(99, 102, 241, 0.2);\n    font-weight: 700;\n    font-size: 0.75rem;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    padding: 0.75rem 1rem;\n}\n\ntbody td {\n    border-bottom: 1px solid rgba(148, 163, 184, 0.10);\n    padding: 0.625rem 1rem;\n    font-size: 0.8125rem;\n}\n\ntbody tr {\n    transition: all 0.2s ease;\n}\n\ntbody tr:hover {\n    background: rgba(99, 102, 241, 0.06);\n    box-shadow: inset 3px 0 0 var(--accent-indigo);\n}\n\n/* ── CHIP / TAG STYLES ── */\n\n.chip, .tag {\n    display: inline-flex;\n    align-items: center;\n    padding: 0.25rem 0.625rem;\n    border-radius: 9999px;\n    font-size: 0.6875rem;\n    font-weight: 600;\n    letter-spacing: 0.04em;\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    transition: all 0.2s ease;\n}\n\n.chip:hover, .tag:hover {\n    transform: scale(1.05);\n    border-color: rgba(255, 255, 255, 0.15);\n}\n\n/* ── ПОСИЛЕНІ RECHARTS ГРАФІКИ ── */\n\n.recharts-text,\n.recharts-cartesian-axis-tick text,\n.recharts-legend-item-text {\n    fill: #e2e8f0 !important;\n    font-size: 11px;\n    font-weight: 500;\n}\n\n.recharts-default-tooltip {\n    background: rgba(2, 6, 23, 0.96) !important;\n    border: 1px solid rgba(99, 102, 241, 0.25) !important;\n    color: #f1f5f9 !important;\n    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6), 0 0 20px rgba(99, 102, 241, 0.1) !important;\n    border-radius: 12px !important;\n    padding: 12px 16px !important;\n    backdrop-filter: blur(20px) !important;\n}\n\n.recharts-tooltip-label {\n    color: #f8fafc !important;\n    font-weight: 700 !important;\n    margin-bottom: 8px !important;\n}\n\n.recharts-tooltip-item {\n    color: #cbd5e1 !important;\n    font-size: 12px !important;\n}\n\n/* ── PULSE DOT INDICATOR ── */\n\n@keyframes pulse-dot {\n    0%, 100% {\n        opacity: 1;\n        box-shadow: 0 0 4px currentColor;\n    }\n    50% {\n        opacity: 0.5;\n        box-shadow: 0 0 12px currentColor, 0 0 24px currentColor;\n    }\n}\n\n.pulse-dot {\n    animation: pulse-dot 2s ease-in-out infinite;\n}\n\n/* ── FADE-IN ANIMATION ── */\n\n@keyframes fade-in-up {\n    from {\n        opacity: 0;\n        transform: translateY(12px);\n    }\n    to {\n        opacity: 1;\n        transform: translateY(0);\n    }\n}\n\n.animate-fade-in-up {\n    animation: fade-in-up 0.5s cubic-bezier(0.23, 1, 0.32, 1) forwards;\n}\n\n/* Stagger delays for lists */\n\n.stagger-1 { animation-delay: 0.05s; }\n\n.stagger-2 { animation-delay: 0.10s; }\n\n.stagger-3 { animation-delay: 0.15s; }\n\n.stagger-4 { animation-delay: 0.20s; }\n\n.stagger-5 { animation-delay: 0.25s; }\n\n.stagger-6 { animation-delay: 0.30s; }\n\n/* ── GRADIENT BORDER GLOW ── */\n\n@keyframes border-glow-pulse {\n    0%, 100% { opacity: 0.5; }\n    50% { opacity: 1; }\n}\n\n.border-glow {\n    position: relative;\n}\n\n.border-glow::before {\n    content: '';\n    position: absolute;\n    inset: -1px;\n    border-radius: inherit;\n    padding: 1px;\n    background: linear-gradient(135deg, rgba(99, 102, 241, 0.4), rgba(6, 182, 212, 0.3), rgba(16, 185, 129, 0.2));\n    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\n    -webkit-mask-composite: xor;\n    mask-composite: exclude;\n    animation: border-glow-pulse 4s ease-in-out infinite;\n    pointer-events: none;\n}\n\n/* ── КРАЩІ SKELETON-ЛОАДЕРИ ── */\n\n@keyframes premium-shimmer {\n    0% { background-position: -200% 0; }\n    100% { background-position: 200% 0; }\n}\n\n.skeleton-premium {\n    background: linear-gradient(\n        90deg,\n        rgba(15, 23, 42, 0.6) 0%,\n        rgba(30, 41, 59, 0.4) 25%,\n        rgba(51, 65, 85, 0.3) 50%,\n        rgba(30, 41, 59, 0.4) 75%,\n        rgba(15, 23, 42, 0.6) 100%\n    );\n    background-size: 200% 100%;\n    animation: premium-shimmer 2s ease-in-out infinite;\n    border-radius: 8px;\n}\n\n/* ── ЧИСЛО / МЕТРИКА ВИДІЛЕННЯ ── */\n\n.metric-value {\n    font-variant-numeric: tabular-nums;\n    font-feature-settings: 'tnum';\n    letter-spacing: -0.02em;\n    font-weight: 800;\n}\n\n/* ── AMBIENT BREATHING BACKGROUND ── */\n\n@keyframes ambient-breathe {\n    0%, 100% { opacity: 0.6; }\n    50% { opacity: 1; }\n}\n\n.ambient-breathe {\n    animation: ambient-breathe 8s ease-in-out infinite;\n}\n\n/* ── NOTIFICATION BADGE ── */\n\n@keyframes notif-bounce {\n    0%, 100% { transform: scale(1); }\n    50% { transform: scale(1.2); }\n}\n\n.notif-badge {\n    animation: notif-bounce 2s ease-in-out infinite;\n    box-shadow: 0 0 8px currentColor;\n}\n\n/* ── ВИКОНАВСЬКА СТРІЧКА STATUS BAR ── */\n\n.status-bar-glow {\n    background: linear-gradient(90deg,\n        rgba(16, 185, 129, 0.15),\n        rgba(6, 182, 212, 0.1),\n        rgba(99, 102, 241, 0.15)\n    );\n    box-shadow: 0 -1px 0 rgba(255, 255, 255, 0.05);\n}\n\n/* === PREMIUM DATA STREAM OVERLAY === */\n\n@keyframes op-data-stream {\n  0% { transform: translateY(-100%) scaleY(0.5); opacity: 0; }\n  10% { opacity: 0.8; }\n  90% { opacity: 0.8; }\n  100% { transform: translateY(100vh) scaleY(1.5); opacity: 0; }\n}\n\n.op-data-streams {\n  position: absolute;\n  inset: 0;\n  pointer-events: none;\n  z-index: 2;\n  overflow: hidden;\n}\n\n.op-stream {\n  position: absolute;\n  top: 0;\n  width: 1px;\n  height: 15vh;\n  background: linear-gradient(to bottom, transparent, var(--op-primary), var(--op-glow), transparent);\n  animation: op-data-stream linear infinite;\n  opacity: 0;\n}\n\n.op-stream:nth-child(1) { left: 10%; animation-duration: 4s; animation-delay: 0s; }\n\n.op-stream:nth-child(2) { left: 25%; animation-duration: 3s; animation-delay: 1.5s; width: 2px; }\n\n.op-stream:nth-child(3) { left: 45%; animation-duration: 5s; animation-delay: 0.7s; }\n\n.op-stream:nth-child(4) { left: 65%; animation-duration: 2.5s; animation-delay: 2.1s; }\n\n.op-stream:nth-child(5) { left: 85%; animation-duration: 4.5s; animation-delay: 0.3s; width: 2px; }\n\n.op-stream:nth-child(6) { left: 95%; animation-duration: 6s; animation-delay: 1.1s; }\n\n/* ═══ PREDATOR BOOT SCREEN ANIMATIONS ═══ */\n\n/* Курсор термінала */\n\n@keyframes blink {\n  0%, 100% { opacity: 1; }\n  50%       { opacity: 0; }\n}\n\n/* Вертикальна сканлінія в лого PREDATOR */\n\n@keyframes scan {\n  0%   { top: -2px; opacity: 1; }\n  80%  { opacity: 1; }\n  100% { top: calc(100% + 2px); opacity: 0; }\n}\n\n/* Горизонтальний глітч */\n\n@keyframes scanline-fast {\n  0%   { transform: translateY(-100%); opacity: 0.6; }\n  100% { transform: translateY(100vh); opacity: 0; }\n}\n\n/* Пульсуюче навантаження (smooth wave) */\n\n@keyframes pulse-slow {\n  0%, 100% { opacity: 0.4; transform: scale(1); }\n  50%       { opacity: 0.9; transform: scale(1.03); }\n}\n\n.animate-pulse-slow {\n  animation: pulse-slow 4s ease-in-out infinite;\n}\n\n/* Глітч-зміщення тексту */\n\n@keyframes glitch {\n  0%   { clip-path: inset(0 0 100% 0); transform: translate(0); }\n  20%  { clip-path: inset(30% 0 50% 0); transform: translate(-3px, 1px); }\n  40%  { clip-path: inset(60% 0 20% 0); transform: translate(3px, -1px); }\n  60%  { clip-path: inset(80% 0 5%  0); transform: translate(-2px, 2px); }\n  80%  { clip-path: inset(10% 0 70% 0); transform: translate(2px, -2px); }\n  100% { clip-path: inset(100% 0 0 0); transform: translate(0); }\n}\n\n/* ════════════════════════════════════════════════════════════════\n   PREDATOR v58.2 — SECTION-CARD DESIGN SYSTEM\n   ════════════════════════════════════════════════════════════════ */\n\n.page-section {\n  position: relative;\n  border-radius: 20px;\n  padding: 1.5rem;\n  margin-bottom: 1.5rem;\n  overflow: hidden;\n  transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);\n}\n\n.page-section::before {\n  content: '';\n  position: absolute;\n  top: 0; left: 0; right: 0;\n  height: 2px;\n  border-radius: 20px 20px 0 0;\n  background: var(--section-accent-line, rgba(255,255,255,0.1));\n}\n\n.section-emerald {\n  background: linear-gradient(145deg, rgba(16,185,129,0.04) 0%, rgba(2,8,20,0.95) 60%);\n  border: 1px solid rgba(16,185,129,0.14);\n  --section-accent-line: linear-gradient(90deg, transparent, rgba(16,185,129,0.7), transparent);\n}\n\n.section-cyan {\n  background: linear-gradient(145deg, rgba(6,182,212,0.04) 0%, rgba(2,8,20,0.95) 60%);\n  border: 1px solid rgba(6,182,212,0.14);\n  --section-accent-line: linear-gradient(90deg, transparent, rgba(6,182,212,0.7), transparent);\n}\n\n.section-amber {\n  background: linear-gradient(145deg, rgba(245,158,11,0.04) 0%, rgba(2,8,20,0.95) 60%);\n  border: 1px solid rgba(245,158,11,0.14);\n  --section-accent-line: linear-gradient(90deg, transparent, rgba(245,158,11,0.7), transparent);\n}\n\n.section-indigo {\n  background: linear-gradient(145deg, rgba(99,102,241,0.04) 0%, rgba(2,8,20,0.95) 60%);\n  border: 1px solid rgba(99,102,241,0.14);\n  --section-accent-line: linear-gradient(90deg, transparent, rgba(99,102,241,0.7), transparent);\n}\n\n.section-violet {\n  background: linear-gradient(145deg, rgba(139,92,246,0.04) 0%, rgba(2,8,20,0.95) 60%);\n  border: 1px solid rgba(139,92,246,0.14);\n  --section-accent-line: linear-gradient(90deg, transparent, rgba(139,92,246,0.7), transparent);\n}\n\n.section-slate {\n  background: linear-gradient(145deg, rgba(100,116,139,0.04) 0%, rgba(2,8,20,0.95) 60%);\n  border: 1px solid rgba(100,116,139,0.14);\n  --section-accent-line: linear-gradient(90deg, transparent, rgba(100,116,139,0.5), transparent);\n}\n\n.section-rose {\n  background: linear-gradient(145deg, rgba(244,63,94,0.04) 0%, rgba(2,8,20,0.95) 60%);\n  border: 1px solid rgba(244,63,94,0.14);\n  --section-accent-line: linear-gradient(90deg, transparent, rgba(244,63,94,0.7), transparent);\n}\n\n.section-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  padding: 4px 10px;\n  border-radius: 100px;\n  font-size: 9px;\n  font-weight: 800;\n  letter-spacing: 0.14em;\n  text-transform: uppercase;\n  border: 1px solid;\n}\n\n.section-badge-emerald { background: rgba(16,185,129,0.12); border-color: rgba(16,185,129,0.25); color: #6ee7b7; }\n\n.section-badge-cyan    { background: rgba(6,182,212,0.12);  border-color: rgba(6,182,212,0.25);  color: #67e8f9; }\n\n.section-badge-amber   { background: rgba(245,158,11,0.12); border-color: rgba(245,158,11,0.25); color: #fcd34d; }\n\n.section-badge-indigo  { background: rgba(99,102,241,0.12); border-color: rgba(99,102,241,0.25); color: #a5b4fc; }\n\n.section-badge-violet  { background: rgba(139,92,246,0.12); border-color: rgba(139,92,246,0.25); color: #c4b5fd; }\n\n.section-badge-rose    { background: rgba(244,63,94,0.12);  border-color: rgba(244,63,94,0.25);  color: #fda4af; }\n\n.section-badge-slate   { background: rgba(100,116,139,0.12); border-color: rgba(100,116,139,0.22); color: #94a3b8; }\n\n.section-dot-emerald { width:8px; height:8px; border-radius:50%; background:#10b981; box-shadow:0 0 8px rgba(16,185,129,0.7); }\n\n.section-dot-cyan    { width:8px; height:8px; border-radius:50%; background:#06b6d4; box-shadow:0 0 8px rgba(6,182,212,0.7);   }\n\n.section-dot-amber   { width:8px; height:8px; border-radius:50%; background:#f59e0b; box-shadow:0 0 8px rgba(245,158,11,0.7);  }\n\n.section-dot-indigo  { width:8px; height:8px; border-radius:50%; background:#6366f1; box-shadow:0 0 8px rgba(99,102,241,0.7);  }\n\n.section-dot-violet  { width:8px; height:8px; border-radius:50%; background:#8b5cf6; box-shadow:0 0 8px rgba(139,92,246,0.7);  }\n\n.section-dot-rose    { width:8px; height:8px; border-radius:50%; background:#f43f5e; box-shadow:0 0 8px rgba(244,63,94,0.7);   }\n\n.section-dot-slate   { width:8px; height:8px; border-radius:50%; background:#64748b; box-shadow:0 0 6px rgba(100,116,139,0.5); }\n\n/* ── METRIC CARDS ── */\n\n.metric-card {\n  background: rgba(255,255,255,0.025);\n  border: 1px solid rgba(255,255,255,0.07);\n  border-radius: 16px;\n  padding: 1rem 1.25rem;\n  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);\n  position: relative;\n  overflow: hidden;\n}\n\n.metric-card:hover {\n  background: rgba(255,255,255,0.04);\n  border-color: rgba(255,255,255,0.12);\n  transform: translateY(-2px);\n  box-shadow: 0 12px 40px rgba(0,0,0,0.4);\n}\n\n.metric-label {\n  font-size: 9px; font-weight: 800;\n  letter-spacing: 0.18em; text-transform: uppercase;\n  color: #475569; margin-bottom: 6px; display: block;\n}\n\n.metric-value-lg {\n  font-size: 1.75rem; font-weight: 900;\n  letter-spacing: -0.03em; line-height: 1;\n  font-variant-numeric: tabular-nums; color: #f8fafc;\n}\n\n/* ── RISK BADGES ── */\n\n.risk-badge {\n  display: inline-flex; align-items: center; gap: 4px;\n  padding: 3px 8px; border-radius: 100px;\n  font-size: 9px; font-weight: 800;\n  letter-spacing: 0.12em; text-transform: uppercase; border: 1px solid;\n}\n\n.risk-critical { background: rgba(244,63,94,0.15); border-color: rgba(244,63,94,0.35); color: #fda4af; }\n\n.risk-high     { background: rgba(249,115,22,0.15); border-color: rgba(249,115,22,0.35); color: #fdba74; }\n\n.risk-medium   { background: rgba(245,158,11,0.15); border-color: rgba(245,158,11,0.30); color: #fcd34d; }\n\n.risk-low      { background: rgba(16,185,129,0.12); border-color: rgba(16,185,129,0.25); color: #6ee7b7; }\n\n.risk-none     { background: rgba(100,116,139,0.12); border-color: rgba(100,116,139,0.20); color: #94a3b8; }\n\n/* ── STATUS INDICATORS ── */\n\n@keyframes status-pulse {\n  0%, 100% { opacity: 1; box-shadow: 0 0 4px currentColor; }\n  50% { opacity: 0.6; box-shadow: 0 0 12px currentColor, 0 0 20px currentColor; }\n}\n\n.status-dot {\n  width: 7px; height: 7px; border-radius: 50%; display: inline-block; flex-shrink: 0;\n}\n\n.status-dot-online  { background: #10b981; animation: status-pulse 2s infinite; color: #10b981; }\n\n.status-dot-warning { background: #f59e0b; animation: status-pulse 1.5s infinite; color: #f59e0b; }\n\n.status-dot-error   { background: #f43f5e; animation: status-pulse 1s infinite; color: #f43f5e; }\n\n.status-dot-offline { background: #475569; }\n\n/* ── EMPTY STATE ── */\n\n.empty-state {\n  display: flex; flex-direction: column;\n  align-items: center; justify-content: center;\n  padding: 3rem 2rem; text-align: center; gap: 0.75rem;\n}\n\n.empty-state-title { font-size: 15px; font-weight: 700; color: #e2e8f0; }\n\n.empty-state-desc  { font-size: 12px; color: #64748b; line-height: 1.6; max-width: 280px; }\n\n/* ── CARDS GRID ── */\n\n.cards-grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }\n\n.cards-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }\n\n.cards-grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }\n\n@media (max-width: 1280px) { .cards-grid-4 { grid-template-columns: repeat(2, 1fr); } }\n\n@media (max-width: 768px)  { .cards-grid-2, .cards-grid-3, .cards-grid-4 { grid-template-columns: 1fr; } }\n\n/* ── PREDATOR INPUT ── */\n\n.predator-input {\n  width: 100%;\n  background: rgba(255,255,255,0.04);\n  border: 1px solid rgba(255,255,255,0.09);\n  border-radius: 12px;\n  color: #f1f5f9;\n  font-size: 13px;\n  padding: 0.625rem 1rem;\n  outline: none;\n  transition: all 0.25s ease;\n  font-family: var(--font-sans, 'Plus Jakarta Sans', sans-serif);\n}\n\n.predator-input::-moz-placeholder { color: #475569; }\n\n.predator-input::placeholder { color: #475569; }\n\n.predator-input:hover  { border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.05); }\n\n.predator-input:focus  { border-color: rgba(99,102,241,0.5); box-shadow: 0 0 0 3px rgba(99,102,241,0.12); }\n\n/* ── CHART CONTAINER ── */\n\n.chart-container {\n  border-radius: 16px;\n  background: rgba(255,255,255,0.02);\n  border: 1px solid rgba(255,255,255,0.06);\n  padding: 1rem;\n  position: relative; overflow: hidden;\n}\n\n.chart-container::before {\n  content: '';\n  position: absolute; inset: 0;\n  background: radial-gradient(ellipse at 50% 0%, rgba(99,102,241,0.04), transparent 60%);\n  pointer-events: none;\n}\n\n/* ── PRIORITY INDICATOR ── */\n\n.hover-reveal-child { opacity: 0; transform: translateY(4px); transition: all 0.2s ease; }\n\n.hover-reveal-parent:hover .hover-reveal-child { opacity: 1; transform: translateY(0); }\n\n/* ── SECTION HEADER ── */\n\n.section-header {\n  display: flex; align-items: center; gap: 12px;\n  margin-bottom: 1.25rem;\n  padding-bottom: 0.875rem;\n  border-bottom: 1px solid rgba(255,255,255,0.06);\n}\n\n.section-title    { font-size: 0.875rem; font-weight: 700; color: #f8fafc; letter-spacing: -0.01em; }\n\n.section-subtitle { font-size: 0.75rem; color: #64748b; margin-top: 2px; }\n\n/* ── SUPREME UTILITIES ── */\n\n.shadow-3xl { box-shadow: 0 60px 100px -30px rgba(0,0,0,0.8); }\n\n.no-scrollbar::-webkit-scrollbar { display: none; }\n\n.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n/* ═══════════════════════════════════════════════════\n   PREDATOR v64.0-WRAITH — CLASSIFICATION & THREAT SYSTEM\n   Гриф секретності, тактичні HUD-елементи, загрозливі ефекти\n   ═══════════════════════════════════════════════════ */\n\n/* ── CLASSIFICATION BANNER ── */\n\n.classification-banner {\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 1rem;\n  padding: 0.2rem 0;\n  font-family: var(--font-mono);\n  font-size: 0.45rem;\n  font-weight: 900;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  color: #c41230;\n  background: rgba(20, 15, 15, 0.95);\n  border-bottom: 1px solid rgba(196, 18, 48, 0.2);\n}\n\n.classification-dot {\n  width: 3px; height: 3px;\n  background: #c41230;\n  border-radius: 50%;\n}\n\n/* ── THREAT LEVEL INDICATOR ── */\n\n.threat-level-bar {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 0.3rem 0.6rem;\n  background: rgba(20, 15, 15, 0.95);\n  border: 1px solid rgba(196, 18, 48, 0.2);\n  border-radius: 2px;\n  font-family: var(--font-mono);\n  font-size: 0.45rem;\n  font-weight: 900;\n  letter-spacing: 0.2em;\n  text-transform: uppercase;\n  color: #c41230;\n}\n\n.threat-level-segments {\n  display: flex;\n  gap: 2px;\n}\n\n.threat-segment {\n  width: 6px; height: 10px;\n  background: rgba(196, 18, 48, 0.2);\n  border-radius: 1px;\n  transition: all 0.3s ease;\n}\n\n.threat-segment.active {\n  background: #c41230;\n}\n\n.threat-segment.active.critical {\n  background: #8b1a1a;\n}\n\n/* ── TACTICAL RETICLE ── */\n\n.tactical-reticle {\n  position: relative;\n}\n\n.tactical-reticle::before,\n.tactical-reticle::after {\n  content: '';\n  position: absolute;\n  pointer-events: none;\n  z-index: 20;\n  opacity: 0.15;\n  transition: opacity 0.3s ease;\n}\n\n.tactical-reticle:hover::before,\n.tactical-reticle:hover::after {\n  opacity: 0.35;\n}\n\n.tactical-reticle::before {\n  top: 6px; left: 6px;\n  width: 16px; height: 16px;\n  border-top: 1px solid #ff1744;\n  border-left: 1px solid #ff1744;\n}\n\n.tactical-reticle::after {\n  bottom: 6px; right: 6px;\n  width: 16px; height: 16px;\n  border-bottom: 1px solid #ff1744;\n  border-right: 1px solid #ff1744;\n}\n\n/* ── SHADOW PULSE GLOW ── */\n\n@keyframes shadow-pulse-glow {\n  0%, 100% {\n    box-shadow:\n      0 0 20px rgba(255,23,68,0.15),\n      0 0 60px rgba(255,23,68,0.05),\n      inset 0 0 20px rgba(255,23,68,0.03);\n  }\n  50% {\n    box-shadow:\n      0 0 35px rgba(255,23,68,0.3),\n      0 0 90px rgba(255,23,68,0.1),\n      inset 0 0 30px rgba(255,23,68,0.06);\n  }\n}\n\n.shadow-pulse-glow {\n  animation: shadow-pulse-glow 4s ease-in-out infinite;\n}\n\n/* ── MILITARY GRID OVERLAY ── */\n\n.military-grid {\n  position: relative;\n}\n\n.military-grid::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  pointer-events: none;\n  z-index: 0;\n  opacity: 0.03;\n  background-image:\n    linear-gradient(rgba(255,23,68,0.5) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(255,23,68,0.5) 1px, transparent 1px);\n  background-size: 80px 80px;\n}\n\n/* ── INTEL CLASSIFICATION STAMP ── */\n\n.intel-stamp {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.4rem;\n  padding: 0.2rem 0.6rem;\n  font-family: var(--font-mono);\n  font-size: 0.45rem;\n  font-weight: 900;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  border: 1px solid;\n  border-radius: 2px;\n  -webkit-user-select: none;\n     -moz-user-select: none;\n          user-select: none;\n}\n\n.intel-stamp.top-secret {\n  color: #ff1744;\n  border-color: rgba(255,23,68,0.5);\n  background: rgba(255,23,68,0.08);\n}\n\n.intel-stamp.confidential {\n  color: #ff6d00;\n  border-color: rgba(255,109,0,0.5);\n  background: rgba(255,109,0,0.08);\n}\n\n.intel-stamp.restricted {\n  color: #ffd600;\n  border-color: rgba(255,214,0,0.5);\n  background: rgba(255,214,0,0.08);\n}\n\n/* ── AGGRESSIVE GLASS CARD ── */\n\n.glass-threat {\n  background: rgba(20, 20, 22, 0.95);\n  border: 1px solid rgba(196, 18, 48, 0.15);\n  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);\n  transition: all 0.3s ease;\n}\n\n.glass-threat:hover {\n  border-color: rgba(196, 18, 48, 0.3);\n  box-shadow: 0 12px 48px rgba(0, 0, 0, 0.8);\n  transform: translateY(-2px);\n}\n\n/* ── BLOOD ACCENT LINE ── */\n\n.blood-accent {\n  position: relative;\n}\n\n.blood-accent::after {\n  content: '';\n  position: absolute;\n  bottom: 0;\n  left: 0;\n  right: 0;\n  height: 2px;\n  background: linear-gradient(90deg, transparent, #ff1744, #b71c1c, transparent);\n  opacity: 0.6;\n}\n\n/* ── TACTICAL SCAN FRAME ── */\n\n@keyframes scan-frame-pulse {\n  0%, 100% { border-color: rgba(255,23,68,0.1); }\n  50% { border-color: rgba(255,23,68,0.3); }\n}\n\n.scan-frame {\n  border: 1px solid rgba(255,23,68,0.15);\n  animation: scan-frame-pulse 4s ease-in-out infinite;\n  position: relative;\n}\n\n.scan-frame::before {\n  content: '';\n  position: absolute;\n  top: -1px;\n  left: 20%;\n  right: 20%;\n  height: 1px;\n  background: #ff1744;\n  box-shadow: 0 0 10px #ff1744;\n  opacity: 0.7;\n}\n\n/* ── DARK COMMAND SURFACE ── */\n\n.command-surface {\n  background: linear-gradient(180deg, rgba(0,0,0,0.95) 0%, rgba(5,2,2,0.9) 100%);\n  border: 1px solid rgba(255,255,255,0.04);\n  box-shadow:\n    0 30px 80px rgba(0,0,0,0.9),\n    inset 0 1px 0 rgba(255,255,255,0.02);\n}\n\n/* ── CRITICAL ALERT RING ── */\n\n@keyframes alert-ring {\n  0% { box-shadow: 0 0 0 0 rgba(255,23,68,0.5); }\n  100% { box-shadow: 0 0 0 12px rgba(255,23,68,0); }\n}\n\n.alert-ring {\n  animation: alert-ring 2s ease-out infinite;\n  border-radius: 50%;\n}\n\n/* ── ENHANCED GLASS-WRAITH v64.0 ── */\n\n.glass-wraith-v64 {\n  background: rgba(20, 20, 22, 0.97);\n  border: 1px solid rgba(196, 18, 48, 0.15);\n  box-shadow: 0 12px 48px rgba(0, 0, 0, 0.7);\n  transition: all 0.3s ease;\n}\n\n.glass-wraith-v64:hover {\n  border-color: rgba(196, 18, 48, 0.3);\n  box-shadow: 0 16px 56px rgba(0, 0, 0, 0.85);\n  transform: translateY(-2px);\n}\n\n/* ── THERMAL HOVER EFFECT v65.0 ── */\n\n.thermal-hover {\n  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);\n  position: relative;\n  overflow: hidden;\n}\n\n.thermal-hover::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: radial-gradient(circle at 50% 0%, rgba(245, 158, 11, 0.12), transparent 60%);\n  opacity: 0;\n  transition: opacity 0.4s ease;\n  pointer-events: none;\n}\n\n.thermal-hover:hover {\n  border-color: rgba(245, 158, 11, 0.35);\n  box-shadow: 0 8px 32px rgba(245, 158, 11, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.04);\n  transform: translateY(-1px);\n}\n\n.thermal-hover:hover::before {\n  opacity: 1;\n}\n\n/* ── GLASS THERMAL CARD ── */\n\n.glass-thermal {\n  background: rgba(5, 5, 5, 0.85);\n  backdrop-filter: blur(20px) saturate(180%);\n  -webkit-backdrop-filter: blur(20px) saturate(180%);\n  border: 1px solid rgba(255, 255, 255, 0.06);\n  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);\n  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);\n  position: relative;\n  overflow: hidden;\n}\n\n.glass-thermal::after {\n  content: '';\n  position: absolute;\n  top: -50%;\n  left: -50%;\n  width: 200%;\n  height: 200%;\n  background: linear-gradient(45deg, transparent 45%, rgba(245, 158, 11, 0.04) 50%, transparent 55%);\n  opacity: 0;\n  transition: opacity 0.5s ease;\n  pointer-events: none;\n}\n\n.glass-thermal:hover {\n  border-color: rgba(245, 158, 11, 0.25);\n  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.7), 0 0 20px rgba(245, 158, 11, 0.08);\n  transform: translateY(-2px);\n}\n\n.glass-thermal:hover::after {\n  opacity: 1;\n  animation: thermal-sweep 2s linear infinite;\n}\n\n@keyframes thermal-sweep {\n  0% { transform: translate(-30%, -30%) rotate(0deg); }\n  100% { transform: translate(30%, 30%) rotate(360deg); }\n}\n\n/* ── GRID GLOW BACKGROUND ── */\n\n.grid-glow {\n  background-image:\n    linear-gradient(rgba(225, 29, 72, 0.06) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(225, 29, 72, 0.06) 1px, transparent 1px);\n  background-size: 40px 40px;\n  position: relative;\n}\n\n.grid-glow::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(225, 29, 72, 0.06) 0%, transparent 40%);\n  pointer-events: none;\n  z-index: 0;\n}\n\n/* ── MOBILE SAFE AREA & TOUCH UTILITIES ── */\n\n.safe-area-top {\n  padding-top: env(safe-area-inset-top);\n}\n\n.safe-area-bottom {\n  padding-bottom: env(safe-area-inset-bottom);\n}\n\n.safe-area-left {\n  padding-left: env(safe-area-inset-left);\n}\n\n.safe-area-right {\n  padding-right: env(safe-area-inset-right);\n}\n\n.safe-area-pb {\n  padding-bottom: calc(env(safe-area-inset-bottom) + 0.5rem);\n}\n\n/* Touch optimization */\n\n/* Mobile typography scale */\n\n@media (max-width: 639px) {\n  .mobile-text-xs { font-size: 0.625rem; line-height: 1rem; }\n  .mobile-text-sm { font-size: 0.75rem; line-height: 1.25rem; }\n  .mobile-text-base { font-size: 0.875rem; line-height: 1.375rem; }\n}\n\n/* Prevent text selection on interactive elements (mobile) */\n\n.no-select {\n  -moz-user-select: none;\n       user-select: none;\n  -webkit-user-select: none;\n}\n\n/* ── AURUM OBSIDIAN GLASS v2.0 ── */\n\n.glass-obsidian {\n  background: var(--glass-bg);\n  backdrop-filter: blur(20px) saturate(120%);\n  -webkit-backdrop-filter: blur(20px) saturate(120%);\n  border: 1px solid var(--glass-border);\n  box-shadow: 0 0 0 1px rgba(0,0,0,0.5), var(--glass-shadow), var(--glass-inset);\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  position: relative;\n  overflow: hidden;\n}\n\n.glass-obsidian::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, transparent 40%);\n  pointer-events: none;\n  z-index: 0;\n}\n\n/* Scan line overlay */\n\n.scan-lines {\n  position: relative;\n}\n\n.scan-lines::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: repeating-linear-gradient(\n    0deg,\n    transparent,\n    transparent 2px,\n    rgba(0, 0, 0, 0.03) 2px,\n    rgba(0, 0, 0, 0.03) 4px\n  );\n  pointer-events: none;\n  z-index: 999;\n  animation: scan-drift 20s linear infinite;\n}\n\n@keyframes scan-drift {\n  0% { background-position: 0 0; }\n  100% { background-position: 0 100vh; }\n}\n\n/* Chromatic aberration on hover */\n\n.chromatic-hover {\n  transition: text-shadow 0.15s ease;\n}\n\n.chromatic-hover:hover {\n  text-shadow:\n    calc(var(--chromatic-offset) * -1) 0 0 rgba(255, 0, 0, 0.3),\n    var(--chromatic-offset) 0 0 rgba(0, 255, 255, 0.3);\n}\n\n/* Aurum gradient text */\n\n.text-aurum {\n  background: linear-gradient(135deg, var(--aurum-gold) 0%, var(--elite-red) 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n/* Vignette effect */\n\n.vignette {\n  position: relative;\n}\n\n.vignette::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.4) 100%);\n  pointer-events: none;\n  z-index: 1;\n}\n\n/* Noise texture overlay */\n\n.noise-overlay {\n  position: relative;\n}\n\n.noise-overlay::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\");\n  opacity: 0.02;\n  pointer-events: none;\n  z-index: 999;\n}\n\n/* Tabular nums для даних */\n\n.font-data {\n  font-family: 'IBM Plex Mono', monospace;\n  font-variant-numeric: tabular-nums;\n  font-feature-settings: 'tnum';\n}\n\n.font-display {\n  font-family: 'JetBrains Mono', monospace;\n}\n\n.font-interface {\n  font-family: 'Inter', system-ui, sans-serif;\n}\n\n/* Status indicators */\n\n.status-led {\n  width: 6px;\n  height: 6px;\n  border-radius: 50%;\n  display: inline-block;\n}\n\n.status-led--healthy {\n  background: var(--tactical-teal);\n  box-shadow: 0 0 4px var(--tactical-teal-glow);\n  animation: breathe 2s ease-in-out infinite;\n}\n\n.status-led--warning {\n  background: var(--aurum-gold);\n  box-shadow: 0 0 4px var(--aurum-glow);\n  animation: blink 1s step-end infinite;\n}\n\n.status-led--critical {\n  background: var(--elite-red);\n  box-shadow: 0 0 6px var(--elite-red-glow);\n  animation: blink 0.5s step-end infinite;\n}\n\n@keyframes breathe {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.5; }\n}\n\n@keyframes blink {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.3; }\n}\n\n/* Military uppercase labels */\n\n.label-military {\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 0.625rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  color: var(--titanium-muted);\n}\n\n/* Kinetic number display */\n\n.kinetic-value {\n  font-family: 'IBM Plex Mono', monospace;\n  font-variant-numeric: tabular-nums;\n  transition: color 0.2s ease;\n}\n\n.kinetic-value--up {\n  color: var(--tactical-teal);\n}\n\n.kinetic-value--down {\n  color: var(--elite-red);\n}\n\n/* ── ADDITIONAL ANIMATIONS ── */\n\n@keyframes blink-fast {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.3; }\n}\n\n@keyframes blink-slow {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.5; }\n}\n\n.animate-blink-fast {\n  animation: blink-fast 0.5s step-end infinite;\n}\n\n.animate-blink-slow {\n  animation: blink-slow 1s step-end infinite;\n}\n\n.animate-breathe {\n  animation: breathe 2s ease-in-out infinite;\n}\n\n/* Glitch text effect */\n\n.glitch-text {\n  position: relative;\n}\n\n.glitch-text::before,\n.glitch-text::after {\n  content: attr(data-text);\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n}\n\n.glitch-text::before {\n  left: 2px;\n  text-shadow: -1px 0 #e11d48;\n  clip-path: inset(44% 0 61% 0);\n  animation: glitch-anim 2s infinite linear alternate-reverse;\n}\n\n.glitch-text::after {\n  left: -2px;\n  text-shadow: -1px 0 #4ecdc4;\n  clip-path: inset(54% 0 31% 0);\n  animation: glitch-anim 2s infinite linear alternate;\n}\n\n@keyframes glitch-anim {\n  0% { clip-path: inset(20% 0 80% 0); }\n  20% { clip-path: inset(60% 0 10% 0); }\n  40% { clip-path: inset(40% 0 50% 0); }\n  60% { clip-path: inset(80% 0 5% 0); }\n  80% { clip-path: inset(10% 0 70% 0); }\n  100% { clip-path: inset(30% 0 40% 0); }\n}\n\n.selection\\:bg-blue-500\\/30 *::-moz-selection{\n  background-color: rgb(59 130 246 / 0.3);\n}\n\n.selection\\:bg-blue-500\\/30 *::selection{\n  background-color: rgb(59 130 246 / 0.3);\n}\n\n.selection\\:bg-cyan-500\\/30 *::-moz-selection{\n  background-color: rgb(6 182 212 / 0.3);\n}\n\n.selection\\:bg-cyan-500\\/30 *::selection{\n  background-color: rgb(6 182 212 / 0.3);\n}\n\n.selection\\:bg-emerald-500\\/30 *::-moz-selection{\n  background-color: rgb(16 185 129 / 0.3);\n}\n\n.selection\\:bg-emerald-500\\/30 *::selection{\n  background-color: rgb(16 185 129 / 0.3);\n}\n\n.selection\\:bg-rose-500\\/30 *::-moz-selection{\n  background-color: rgb(244 63 94 / 0.3);\n}\n\n.selection\\:bg-rose-500\\/30 *::selection{\n  background-color: rgb(244 63 94 / 0.3);\n}\n\n.selection\\:bg-yellow-500\\/30 *::-moz-selection{\n  background-color: rgb(234 179 8 / 0.3);\n}\n\n.selection\\:bg-yellow-500\\/30 *::selection{\n  background-color: rgb(234 179 8 / 0.3);\n}\n\n.selection\\:bg-blue-500\\/30::-moz-selection{\n  background-color: rgb(59 130 246 / 0.3);\n}\n\n.selection\\:bg-blue-500\\/30::selection{\n  background-color: rgb(59 130 246 / 0.3);\n}\n\n.selection\\:bg-cyan-500\\/30::-moz-selection{\n  background-color: rgb(6 182 212 / 0.3);\n}\n\n.selection\\:bg-cyan-500\\/30::selection{\n  background-color: rgb(6 182 212 / 0.3);\n}\n\n.selection\\:bg-emerald-500\\/30::-moz-selection{\n  background-color: rgb(16 185 129 / 0.3);\n}\n\n.selection\\:bg-emerald-500\\/30::selection{\n  background-color: rgb(16 185 129 / 0.3);\n}\n\n.selection\\:bg-rose-500\\/30::-moz-selection{\n  background-color: rgb(244 63 94 / 0.3);\n}\n\n.selection\\:bg-rose-500\\/30::selection{\n  background-color: rgb(244 63 94 / 0.3);\n}\n\n.selection\\:bg-yellow-500\\/30::-moz-selection{\n  background-color: rgb(234 179 8 / 0.3);\n}\n\n.selection\\:bg-yellow-500\\/30::selection{\n  background-color: rgb(234 179 8 / 0.3);\n}\n\n.file\\:border-0::file-selector-button{\n  border-width: 0px;\n}\n\n.file\\:bg-transparent::file-selector-button{\n  background-color: transparent;\n}\n\n.file\\:text-sm::file-selector-button{\n  font-size: 0.875rem;\n  line-height: 1.25rem;\n}\n\n.file\\:font-medium::file-selector-button{\n  font-weight: 500;\n}\n\n.placeholder\\:uppercase::-moz-placeholder{\n  text-transform: uppercase;\n}\n\n.placeholder\\:uppercase::placeholder{\n  text-transform: uppercase;\n}\n\n.placeholder\\:italic::-moz-placeholder{\n  font-style: italic;\n}\n\n.placeholder\\:italic::placeholder{\n  font-style: italic;\n}\n\n.placeholder\\:text-\\[\\#3a3a3a\\]::-moz-placeholder{\n  --tw-text-opacity: 1;\n  color: rgb(58 58 58 / var(--tw-text-opacity, 1));\n}\n\n.placeholder\\:text-\\[\\#3a3a3a\\]::placeholder{\n  --tw-text-opacity: 1;\n  color: rgb(58 58 58 / v
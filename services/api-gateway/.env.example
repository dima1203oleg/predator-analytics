# ==========================================
# Predator Analytics v26 - Environment Config
# ==========================================
# Copy this file to .env and fill in the values
# DO NOT COMMIT THE ACTUAL .env FILE TO GIT

# --- APP ---
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change_this_to_a_secure_random_string_in_production
ALLOWED_ORIGINS=["*"]

# --- DATABASE ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=secure_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=predator_db

# --- INFRASTRUCTURE ---
REDIS_HOST=redis
RABBITMQ_USER=predator
RABBITMQ_PASSWORD=secure_rabbit_password
RABBITMQ_HOST=rabbitmq
MINIO_ROOT_USER=predator_admin
MINIO_ROOT_PASSWORD=secure_minio_password
MINIO_ENDPOINT=minio:9000
QDRANT_URL=http://qdrant:6333
OPENSEARCH_URL=http://opensearch:9200

# --- SECURITY ---
# HashiCorp Vault (Optional)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=

# --- GEMINI / LLM ---
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- INTEGRATIONS ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=123456789

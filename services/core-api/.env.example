# PREDATOR Analytics Core API - Production Environment Variables
# ═════════════════════════════════════════════════════════════════

# ===========================================
# BASIC SETTINGS
# ===========================================
APP_NAME="PREDATOR Analytics Core API"
APP_VERSION="55.2.0"
DEBUG=false
ENV="production"

# ===========================================
# SECURITY (CRITICAL - CHANGE IN PRODUCTION!)
# ===========================================
# Generate with: openssl rand -hex 32
SECRET_KEY="your-super-secret-key-change-this-in-production-min-32-chars"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ROOT_TENANT_ID="global-system"

# ===========================================
# DATABASE (PostgreSQL 16)
# ===========================================
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL="postgresql+asyncpg://predator:your_password@localhost:5432/predator"

# Alternative format (if DATABASE_URL not set):
POSTGRES_USER="predator"
POSTGRES_PASSWORD="your_password"
POSTGRES_SERVER="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="predator"

# ===========================================
# REDIS (Session caching, rate limiting)
# ===========================================
REDIS_URL="redis://localhost:6379/0"

# ===========================================
# NEO4J (Graph Database)
# ===========================================
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your_neo4j_password"

# ===========================================
# KAFKA / REDPANDA (Event streaming)
# ===========================================
KAFKA_BROKERS="localhost:9092"
KAFKA_OFFLINE_DIR="/tmp/predator_offline"

# ===========================================
# MINIO / S3 (File storage)
# ===========================================
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="your_minio_access_key"
MINIO_SECRET_KEY="your_minio_secret_key"
MINIO_SECURE=false
MINIO_BUCKET_NAME="predator-files"

# ===========================================
# AI / LLM SERVICES
# ===========================================
LITELLM_API_BASE="http://localhost:4000/v1"
OLLAMA_MODEL="llama3"
MCP_ROUTER_URL="http://localhost:8080/v1/query"

# ===========================================
# EXTERNAL SERVICES
# ===========================================
GRAPH_SERVICE_URL="http://localhost:9030"

# ===========================================
# MONITORING & OBSERVABILITY
# ===========================================
PROMETHEUS_ENABLED=true
JAEGER_ENABLED=false
LOG_LEVEL="INFO"

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_SEARCH_REQUESTS_PER_MINUTE=100
RATE_LIMIT_ANALYTICS_REQUESTS_PER_MINUTE=50

# ===========================================
# CORS SETTINGS
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:3030","https://predator.ua"]
CORS_ALLOW_CREDENTIALS=true

# ===========================================
# COMPRESSION
# ===========================================
COMPRESSION_MINIMUM_SIZE=1024

# ===========================================
# CACHE SETTINGS
# ===========================================
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# ===========================================
# CONNECTION POOLS
# ===========================================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
REDIS_POOL_SIZE=10

# ===========================================
# HEALTH CHECKS
# ===========================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT_SECONDS=30

# ===========================================
# DEVELOPMENT ONLY (set to false in production)
# ===========================================
ENABLE_DOCS=false
ENABLE_REDOC=false
ENABLE_OPENAPI=false

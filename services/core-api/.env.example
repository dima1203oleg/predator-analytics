# PREDATOR Analytics Core API v56.5-ELITE — Environment Variables
# ═════════════════════════════════════════════════════════════════
# Канонічний файл конфігурації (TZ v5.0 §6.2)
# Генерувати секрети: openssl rand -hex 32

# ===========================================
# BASIC SETTINGS
# ===========================================
APP_NAME="PREDATOR Analytics Core API"
APP_VERSION="56.5.0-ELITE"
DEBUG=false
ENV="production"
# TESTING=false  # Встановити true для тестового режиму

# ===========================================
# SECURITY (КРИТИЧНО — ЗМІНИТИ В PRODUCTION!)
# HR-06: Секрети НІКОЛИ в коді
# ===========================================
SECRET_KEY="your-super-secret-key-change-this-in-production-min-32-chars"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ROOT_TENANT_ID="global-system"

# ===========================================
# AUTH PROVIDER
# ===========================================
# Варіанти: "keycloak" (production), "simple" (development)
AUTH_PROVIDER="keycloak"
KEYCLOAK_URL="https://keycloak.local"
KEYCLOAK_REALM="predator"
KEYCLOAK_AUDIENCE="predator-api"
KEYCLOAK_CLIENT_ID="predator-api"
KEYCLOAK_ADMIN_URL="https://keycloak.local/admin/realms/predator"

# ===========================================
# DATABASE (PostgreSQL 16 / TimescaleDB)
# ===========================================
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL="postgresql+asyncpg://predator:your_password@localhost:5432/predator"

# Альтернативний формат (використовується якщо DATABASE_URL не встановлено):
POSTGRES_USER="predator"
POSTGRES_PASSWORD="your_password"
POSTGRES_SERVER="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="predator"

# ===========================================
# REDIS 7 (Кешування, rate limiting, feature flags)
# ===========================================
REDIS_URL="redis://localhost:6379/0"

# ===========================================
# NEO4J 5.16 (Graph Database + APOC)
# ===========================================
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your_neo4j_password"

# ===========================================
# OPENSEARCH 2.17 (Full-text search)
# ===========================================
OPENSEARCH_HOSTS="https://localhost:9200"
OPENSEARCH_USERNAME="admin"
OPENSEARCH_PASSWORD="your_opensearch_password"
OPENSEARCH_TLS_VERIFY=false

# ===========================================
# QDRANT (Vector DB для RAG та Entity Resolution)
# ===========================================
QDRANT_URL="http://localhost:6333"
# QDRANT_API_KEY=""  # Опціонально

# ===========================================
# KAFKA / REDPANDA (Event streaming — TZ v5.0 §5.1)
# HR-17: Формат топіків: tenant.{id}.{category}.{name}
# ===========================================
KAFKA_BROKERS="localhost:9092"
KAFKA_OFFLINE_DIR="/tmp/predator_offline"

# Канонічні назви топіків (HR-17)
KAFKA_TOPIC_INGESTION_RAW="tenant.default.ingestion.raw"
KAFKA_TOPIC_INGESTION_CLEANED="tenant.default.ingestion.cleaned"
KAFKA_TOPIC_ENTITY_RESOLUTION="tenant.default.entity.resolution"
KAFKA_TOPIC_ENRICHMENT="tenant.default.enrichment.events"
KAFKA_TOPIC_RISK_ALERTS="tenant.default.risk.alerts"
KAFKA_TOPIC_DLQ="tenant.default.dlq"
KAFKA_TOPIC_QUARANTINE="tenant.default.quarantine"

# ===========================================
# MINIO / S3 (Object storage — файли, бекапи, артефакти)
# ===========================================
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="your_minio_access_key"
MINIO_SECRET_KEY="your_minio_secret_key"
MINIO_SECURE=false
MINIO_BUCKET_RAW_UPLOADS="raw-uploads"
MINIO_BUCKET_PROCESSED="processed-files"
MINIO_BUCKET_REPORTS="reports"

# ===========================================
# AI / LLM SERVICES (MCP Router Tri-State — TZ v5.0 §6.3)
# ===========================================
LITELLM_API_BASE="http://localhost:4000/v1"
LITELLM_MODEL="ollama/glm-5.1:latest"
LITELLM_REASONING_MODEL="ollama/deepseek-r1:latest"
LITELLM_ELITE_MODEL="ollama/glm-5.1:latest"
OLLAMA_MODEL="glm-5.1:latest"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
MCP_ROUTER_URL="http://localhost:8080/v1/query"
AI_ENGINE_URL="http://localhost:9050"
COPILOT_STREAM_BUFFER=100
MLFLOW_TRACKING_URL="http://mlflow-internal.predator.svc:5000"

# ===========================================
# MODULAR SERVICES (Internal URLs)
# ===========================================
GRAPH_SERVICE_URL="http://localhost:9030"
INGESTION_SERVICE_URL="http://localhost:9100"
OSINT_SERVICE_URL="http://localhost:9200"
WORKER_CPU_URL="http://localhost:9300"
WORKER_GPU_URL="http://localhost:9400"
JOB_SCHEDULER_URL="http://localhost:9500"
API_GATEWAY_URL="https://predator.local"

# ===========================================
# РЕЄСТРИ УКРАЇНИ (OSINT)
# ===========================================
EDR_API_KEY="mock"
COURT_API_KEY="mock"
DPS_API_KEY="mock"
YOUCONTROL_API_KEY="mock"
PROZORRO_API_URL="https://public.api.openprocurement.org/api/2.5"

# ===========================================
# MONITORING & OBSERVABILITY (TZ v5.0 §8)
# ===========================================
PROMETHEUS_ENABLED=true
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
LOG_LEVEL="INFO"
# PROMETHEUS_URL="http://localhost:9090"
# GRAFANA_URL="http://localhost:3000"
# LOKI_URL="http://localhost:3100"

# ===========================================
# CORS & PERFORMANCE
# ===========================================
CORS_ORIGINS="http://localhost:3030,http://localhost:3000"
CORS_ALLOW_CREDENTIALS=true
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_ANALYTICS_PER_MINUTE=50
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# ===========================================
# CONNECTION POOLS
# ===========================================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
REDIS_POOL_SIZE=10

# ===========================================
# HEALTH CHECKS
# ===========================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT_SECONDS=30

# ===========================================
# DEVELOPMENT ONLY (false в production)
# ===========================================
ENABLE_DOCS=false
ENABLE_REDOC=false
ENABLE_OPENAPI=false

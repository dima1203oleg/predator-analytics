# PREDATOR Analytics Core API - Remote NVIDIA Server Configuration
# ═════════════════════════════════════════════════════════════════
# Використовується для підключення до віддаленого NVIDIA сервера
# IP: 194.177.1.240

# ===========================================
# BASIC SETTINGS
# ===========================================
APP_NAME="PREDATOR Analytics Core API"
APP_VERSION="56.1.0"
DEBUG=false
ENV="production"

# ===========================================
# SECURITY
# ===========================================
SECRET_KEY="R8IUEmwSJQ7dkeVSxhNOhqUN55GTdhYypY0q21hKN5YSdYVMKFim2AUdTuaaLvCkTy1MaV5baMtXZhgVabMTgw"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ROOT_TENANT_ID="global-system"

# ===========================================
# DATABASE (Remote PostgreSQL on NVIDIA Server)
# ===========================================
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL="postgresql+asyncpg://predator:nvidia-prod-password@194.177.1.240:5432/predator"

# Alternative format (if DATABASE_URL not set):
POSTGRES_USER="predator"
POSTGRES_PASSWORD="nvidia-prod-password"
POSTGRES_SERVER="194.177.1.240"
POSTGRES_PORT="5432"
POSTGRES_DB="predator"

# ===========================================
# REDIS (Remote on NVIDIA Server)
# ===========================================
REDIS_URL="redis://194.177.1.240:6379/0"

# ===========================================
# NEO4J (Graph Database on NVIDIA Server)
# ===========================================
NEO4J_URI="bolt://194.177.1.240:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="nvidia-prod-password"

# ===========================================
# KAFKA / REDPANDA (Event streaming on NVIDIA Server)
# ===========================================
KAFKA_BROKERS="194.177.1.240:9092"
KAFKA_OFFLINE_DIR="/tmp/predator_offline"

# ===========================================
# OPENSEARCH (Search engine on NVIDIA Server)
# ===========================================
OPENSEARCH_URL="http://194.177.1.240:9200"
OPENSEARCH_USER="admin"
OPENSEARCH_PASSWORD="nvidia-prod-password"

# ===========================================
# MINIO (S3-compatible storage on NVIDIA Server)
# ===========================================
MINIO_ENDPOINT="194.177.1.240:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="predator-artifacts"
MINIO_SECURE=false

# ===========================================
# QDRANT (Vector DB on NVIDIA Server)
# ===========================================
QDRANT_URL="http://194.177.1.240:6333"

# ===========================================
# AUTH (Keycloak)
# ===========================================
AUTH_PROVIDER="keycloak"
KEYCLOAK_URL="https://194.177.1.240"
KEYCLOAK_REALM="predator"
KEYCLOAK_AUDIENCE="predator-api"
KEYCLOAK_CLIENT_ID="predator-api"
KEYCLOAK_ADMIN_URL="https://194.177.1.240/admin/realms/predator"

# ===========================================
# ML/AI (LiteLLM, Ollama)
# ===========================================
# ULTRA-ROUTER v55.3 (STATELESS режим на локальній машині)
LITELLM_API_URL="http://localhost:4000"

# Fallback: основний LiteLLM на NVIDIA сервері (якщо локальний не доступний)
LITELLM_API_URL_FALLBACK="http://194.177.1.240:8090"

# Ollama (локально або на сервері)
OLLAMA_API_URL="http://194.177.1.240:11434"

# ===========================================
# FREE AI PROVIDERS (для ULTRA-ROUTER v55.3)
# ===========================================
# 🚀 GROQ (10 ключів — абсолютно безплатно)
# Одержати: https://console.groq.com/keys
GROQ_API_KEY_1="gsk_YOUR_KEY_1_HERE"
GROQ_API_KEY_2="gsk_YOUR_KEY_2_HERE"
GROQ_API_KEY_3="gsk_YOUR_KEY_3_HERE"
GROQ_API_KEY_4="gsk_YOUR_KEY_4_HERE"
GROQ_API_KEY_5="gsk_YOUR_KEY_5_HERE"

# 📚 HUGGINGFACE (безплатно)
# Одержати: https://huggingface.co/settings/tokens
HF_API_KEY="hf_YOUR_API_KEY_HERE"

# 🤝 TOGETHER AI (1M token/день безплатно)
# Одержати: https://www.together.ai/
TOGETHER_API_KEY="b27_YOUR_API_KEY_HERE"

# ===========================================
# MONITORING
# ===========================================
PROMETHEUS_URL="http://194.177.1.240:9090"
GRAFANA_URL="http://194.177.1.240:3000"
LOKI_URL="http://194.177.1.240:3100"

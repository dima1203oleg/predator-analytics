{
  "name": "@devin/visual-tools",
  "version": "1.0.0",
  "description": "Zero-configuration visual testing framework for Electron applications with AI-enhanced autonomous validation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "devin-visual-test": "dist/cli/index.js",
    "devin-visual-init": "dist/cli/init.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "visual-testing",
    "electron",
    "playwright",
    "e2e-testing",
    "automation",
    "ai-testing",
    "regression-testing"
  ],
  "author": "Devin AI",
  "license": "MIT",
  "dependencies": {
    "@playwright/test": "^1.61.0",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.11",
    "semver": "^7.6.0",
    "chokidar": "^3.5.3",
    "diff-match-patch": "^1.0.5",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/diff-match-patch": "^1.0.5",
    "@types/pixelmatch": "^5.4.6",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.9.3",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "prettier": "^3.1.1"
  },
  "peerDependencies": {
    "playwright": "^1.60.0",
    "electron": "^25.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}

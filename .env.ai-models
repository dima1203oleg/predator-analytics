# 🔴 Z.ai GLM Моделі (уже налаштовано)
export ZAI_API_KEY="bd39ed3a72b54632a98eb50515578272.F3D34MOPpAfbP7vg"

# 🔵 Gemini API Key (Google Cloud Platform)
# Отримати на: https://aistudio.google.com/app/apikey
# Free Tier: 2M requests/день, 60 requests/хв
# Додайте Ваш ключ нижче:
export GOOGLE_API_KEY="${GOOGLE_API_KEY:-YOUR_GEMINI_API_KEY_HERE}"

# 🟢 GROQ API Key (вільні LLM через GROQ)
# Отримати на: https://console.groq.com/
# Free Tier: Безлімітні запити (Mixtral, Llama, QWEN)
# Додайте Ваш ключ нижче:
export GROQ_API_KEY="${GROQ_API_KEY:-YOUR_GROQ_API_KEY_HERE}"

# 🟡 Ollama локально
# IP NVIDIA Server
export OLLAMA_API_URL="http://194.177.1.240:11434"

# ⚪ LiteLLM Gateway
export LITELLM_BASE_URL="http://194.177.1.240:4000"
export LITELLM_API_KEY="predator-litellm-secret"
export LITELLM_MASTER_KEY="predator-litellm-secret"

echo "✅ AI Models Configuration Loaded"
echo "   📡 Z.ai: ✓"
echo "   🔵 Gemini: $([ -n \"$GOOGLE_API_KEY\" ] && [ \"$GOOGLE_API_KEY\" != \"YOUR_GEMINI_API_KEY_HERE\" ] && echo '✓' || echo '❌ ПОТРІБЕН КЛЮЧ')"
echo "   🟢 GROQ: $([ -n \"$GROQ_API_KEY\" ] && [ \"$GROQ_API_KEY\" != \"YOUR_GROQ_API_KEY_HERE\" ] && echo '✓' || echo '❌ ПОТРІБЕН КЛЮЧ')"
echo "   🟡 Ollama: http://194.177.1.240:11434"
echo ""
